# Google Cloud NLP service account key path
GOOGLE_APPLICATION_CREDENTIALS=.credentials/nlp-service-account.json

# Screaming Frog CLI path (default for macOS)
SF_CLI_PATH=/Applications/Screaming Frog SEO Spider.app/Contents/MacOS/ScreamingFrogSEOSpiderLauncher

# Temp directory for Screaming Frog crawl output
SF_OUTPUT_DIR=/tmp/entity-salience-crawls
