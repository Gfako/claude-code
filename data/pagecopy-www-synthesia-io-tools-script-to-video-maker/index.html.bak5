document.addEventListener("DOMContentLoaded", () => {
	
	const stickyCTA = document.querySelector('#sticky-bar');
	const videoContainer = stickyCTA.querySelector('.demo-floating-video-wrapper');
	const videoElement = videoContainer.querySelector('video');
	const muteControl = videoContainer.querySelector('[mute-control]');

	
	function unmuteVideo() {
		if (videoElement.muted) {
			videoElement.currentTime = 0;
			videoElement.muted = false;
			videoElement.loop = false;
			muteControl.style.opacity = 0;
		}
		else {
			videoElement.muted = true;
			muteControl.style.opacity = 1;
		}
	}
	

	function videoEnded() {
	    videoElement.muted = true;
	    videoElement.loop = true;
	    videoElement.currentTime = 0;
	    muteControl.style.opacity = 1;
	    videoElement.play().catch(() => {});
	}


	// Attach toggleMute to the mute control button
	if (muteControl) {
	    muteControl.addEventListener('click', unmuteVideo);
	}
	// Attach event listener for video click to unmute only
	if (videoElement) {
	    videoElement.addEventListener('click', unmuteVideo);
	    videoElement.addEventListener('ended', videoEnded);
	}
	
});
</script>
