syn-og-view [data-id="title"] {
display: -webkit-box;
overflow: hidden;
-webkit-line-clamp: 1;
-webkit-box-orient: vertical;
}

syn-og-view [data-id="desc"] {
display: -webkit-box;
overflow: hidden;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
}

@media screen and (max-width: 479px) {
syn-og-view > .flex {
flex-direction: column;
}
.ogview-img {
min-height: auto;
}
.ogview {
max-height: none;
}
}
</style></div><div class="javascript w-embed w-script"><script type="module">
class SYNComponent extends HTMLElement {
    constructor() {
        super();
    }

    connectedCallback() {
    }

    disconnectedCallback() {
    }

    static get observedAttributes() {
        return [];
    }

    show() {
        this.style.display = "flex";
    }

    hide() {
        this.style.display = "none";
    }

    changeUI(state) {
        const evt = new CustomEvent(SYNComponent.EVENTS_CHANGE_UI, {
            bubbles: true,
            cancelable: true,
            detail: {
                from: this,
                uiState: state,
            }
        });
        this.dispatchEvent(evt);
    }
}
SYNComponent.EVENTS_CHANGE_UI = "SYNComponent.EVENTS_CHANGE_UI";
if (!customElements.get("syn-component")) {
    customElements.define("syn-component", SYNComponent);
}
window.SYN = window.SYN || {};
window.SYN.SYNComponent = SYNComponent;
</script></div><div class="javascript w-embed w-script"><script type="module">
class SynOGView extends window.SYN.SYNComponent {
    constructor() {
        super();
        this.hide();
        this.ogApiUrl = "https://lxdhr7i8e0.execute-api.eu-west-1.amazonaws.com/prod/ogview?url={url}";
        this.ogpayload = null;
    }

    connectedCallback() {
        super.connectedCallback();
        this.imgEl = this.querySelector("[data-id='img']");
        this.titleText = this.querySelector("[data-id='title']");
        this.descText = this.querySelector("[data-id='desc']");
    }

    disconnectedCallback() {
        super.disconnectedCallback();
    }

    static get observedAttributes() {
        return ["url"];
    }

    attributeChangedCallback(name, oldValue, newValue) {
        if (name !== "url") return;

        if (!newValue) {
            this._abort?.abort();
            this.hide();
            return;
        }

        this._abort?.abort();
        this._abort = new AbortController();
				
        // const reqUrl = this.ogApiUrl.replace("{url}", newValue);
        const reqUrl = this.ogApiUrl.replace("{url}", encodeURIComponent(newValue));
        
        fetch(reqUrl, {signal: this._abort.signal})
            .then(res => {
                if (!res.ok) throw new Error('Err.');
                return res.json();
            })
            .then(data => {
                if (this.url !== newValue) return;

                this.ogpayload = data;
                this.setDetails(data);
                this.show();
            })
            .catch(err => {
                if (err.name === "AbortError") return;
                console.warn(err);
                this.hide();
            });
    }

    get url() {
        return this.getAttribute("url");
    }

    set url(v) {
        if (v) {
            this.setAttribute("url", v);
        }
    }

    reset() {
        this.hide();
    }

    hide() {
        super.hide();
    }
    
    show() {
        super.show();
    }

    setDetails(data) {
        if (!data) {
            return;
        }
        if (data.image_base64 && data.image_content_type) {
            this.imgEl.src = `data:${data.image_content_type};base64,${data.image_base64}`;
        }
        this.titleText.textContent = `${data.title}`;
        this.descText.textContent = `${data.description}`;
    }
}
if (!customElements.get("syn-og-view")) {
    customElements.define("syn-og-view", SynOGView);
}
window.SYN = window.SYN || {};
window.SYN.SynOGView = SynOGView;
</script></div></section><syn-og-view class="ogview" url=""><div class="width-100-percent flex border-radius-small background-white border-grey-200"><div class="ogview-img"><img class="width-100-percent object-fit-cover" data-id="img"/></div><div class="padding-xxsmall text-align-left"><div class="paragraph-large is-medium text-style-1line" data-id="title">Title</div><div class="paragraph-small text-style-2lines" data-id="desc">Desc</div></div></div></syn-og-view></section></div><div class="padding-horizontal padding-xsmall"><div data-id="cta-bar"><div class="button-secondary is-small" data-id="file-btn"><div class="icon-16 w-embed"><svg fill="none" height="16" viewbox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg">
