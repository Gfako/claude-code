    class ADVideoThumbnail extends ADComponent {
      constructor() {
        super();
      }
  
      connectedCallback() {
        super.connectedCallback();
        this.uploadStatus = this.querySelector("[data-id='uploading']");
        this.uploadStatusResult = this.querySelector("[data-id='upload-result']");
  
        this.thumbnailName1 = this.querySelector("[data-id='uploading'] [data-id='upload-name']");
        this.thumbnailName2 = this.querySelector("[data-id='upload-result'] [data-id='upload-name']");
        this.errorText = this.querySelector("[data-id='upload-fail-text']");
        this.thumbnailDeleteBtn = this.querySelector("[data-id='file-delete-btn']");
  
        this.uploadStatus.style.display = 'none';
        this.uploadStatusResult.style.display = 'none';
        this.errorText.style.display = 'none';
  
        this.thumbnailDeleteBtn.addEventListener('click', this.handleDelete.bind(this));
      }
  
      disconnectedCallback() {
        super.disconnectedCallback();
      }
  
      reset() {
        this.hasErrored(false);
      }
  
      show() {
        this.style.display = 'block';
      }
  
      hide() {
        this.style.display = 'none';
      }
  
      setDetails(imgUrl, title) {
        this.thumbnailName1.textContent = title;
        this.thumbnailName2.textContent = title;
      }
  
      setAsset(file) {
        this.thumbnailName1.textContent = file.name;
        this.thumbnailName2.textContent = file.name;
      }
  
      handleDelete(e) {
        this.thumbnailName1.textContent = '';
        this.thumbnailName2.textContent = '';
        const evt = new CustomEvent(AIVidGenWidget.EVENTS_DELETE_ASSET, {
          bubbles: true,
          cancelable: true,
          detail: {
            from: this,
          },
        });
        this.hide();
        this.dispatchEvent(evt);
      }
  
      hasErrored(v) {
        if (v) {
          this.setAttribute('upload-failed', '');
          this.errorText.style.display = 'block';
        } else {
          this.removeAttribute('upload-failed');
          this.errorText.style.display = 'none';
        }
      }
    }
