    class ADUploadArea extends ADComponent {
      constructor() {
        super();
        this.hide();
      }
  
      connectedCallback() {
        super.connectedCallback();
        this.uploadFn = null;
        this.dropArea = this.querySelector("[data-id='drop-area']");
        this.fileInput = this.querySelector("[data-id='file-input']");
        this.progressGfx = this.querySelector('ad-progress-gfx');
  
        this.thumb = this.querySelector('ad-videothumbnail');
  
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach((eventName) => {
          this.dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            e.stopPropagation();
          });
        });
  
        ['dragenter', 'dragover'].forEach((eventName) => {
          this.dropArea.addEventListener(eventName, () => {
            this.dropArea.classList.add('dragover');
          });
        });
  
        ['dragleave', 'drop'].forEach((eventName) => {
          this.dropArea.addEventListener(eventName, () => {
            this.dropArea.classList.remove('dragover');
          });
        });
  
        const handleFileSelection = async (file) => {
          console.log('handleFileSelection');
          this.dropArea.style.display = 'none';
          this.thumb.setAsset(file);
          this.thumb.show();
          this.thumb.uploadStatus.style.display = 'flex';
          this.thumb.uploadStatusResult.style.display = 'none';
          try {
            const upresult = await this.uploadFn(file, this.progressGfx);
          } finally {
            this.fileInput.value = '';
            this.progressGfx.reset();
            this.thumb.uploadStatus.style.display = 'none';
            this.thumb.uploadStatusResult.style.display = 'flex';
          }
        };
  
        this.dropArea.addEventListener('drop', async (e) => {
          const files = e.dataTransfer.files;
          if (files.length) {
            this.fileInput.files = files;
            await handleFileSelection(files[0]);
          }
        });
  
        this.dropArea.addEventListener('click', () => {
          this.fileInput.click();
        });
  
        this.fileInput.addEventListener('change', () => {
          if (this.fileInput.files.length) {
            handleFileSelection(this.fileInput.files[0]);
          }
        });
      }
  
      disconnectedCallback() {
        super.disconnectedCallback();
      }
  
      show() {
        this.style.display = 'flex';
      }
  
      hide() {
        this.style.display = 'none';
      }
  
      reset() {
        this.progressGfx.reset();
        this.dropArea.style.display = 'flex';
        this.thumb.hide();
      }
  
      setUploadFn(fn) {
        this.uploadFn = fn;
      }
    }
    if (!customElements.get('ad-uploadarea')) {
      customElements.define('ad-uploadarea', ADUploadArea);
    }
  
    class AVGLink extends ADComponent {
      constructor() {
        super();
        this.isValid = false;
      }
  
      connectedCallback() {
        super.connectedCallback();
        this.urlText = this.querySelector("[data-id='url-text']");
        this.urlText.addEventListener('input', this.handleChange.bind(this));
        this.errorText = this.querySelector("[data-id='url-error-text']");
  
        this.errorText.style.display = 'none';
      }
  
      disconnectedCallback() {
        super.disconnectedCallback();
      }
  
      show() {
        this.style.display = 'flex';
        setTimeout(() => {
          this.urlText.focus();
        }, 50);
      }
  
      hide() {
        this.style.display = 'none';
        setTimeout(() => {
          this.urlText.blur();
        }, 50);
      }
  
      reset() {
        this.errorText.style.display = 'none';
        this.urlText.value = null;
        this.urlText.classList.remove('invalid');
        /*
              setTimeout(() => {
                  this.urlText.blur();
              }, 50);
              */
      }
  
      validateLink(str) {
        const httpRegex = /^https?:\/\/[^\s/$.?#].[^\s]*$/i;
        const domainRegex = /^(?!-)[A-Za-z0-9-]{1,63}(?<!-)\.[A-Za-z]{2,}$/;
  
        if (!httpRegex.test(str) && !domainRegex.test(str)) {
          return false;
        }
  
        if (httpRegex.test(str)) {
          try {
            const url = new URL(str);
            return url.protocol === 'http:' || url.protocol === 'https:';
          } catch {
            return false;
          }
        }
  
        return true;
      }
  
      handleChange(e) {
        this.urlText.classList.remove('invalid');
        this.errorText.style.display = 'none';
        if (this.validateLink(this.urlText.value)) {
          this.isValid = true;
          const evt = new CustomEvent(AIVidGenWidget.UI_STATES_LINK_SUCCESS, {
            bubbles: true,
            cancelable: true,
            detail: { from: this },
          });
          this.dispatchEvent(evt);
        } else {
          this.isValid = false;
          this.urlText.classList.add('invalid');
          this.errorText.style.display = 'flex';
          const evt = new CustomEvent(AIVidGenWidget.UI_STATES_LINK_INVALID, {
            bubbles: true,
            cancelable: true,
            detail: { from: this },
          });
          this.dispatchEvent(evt);
        }
      }
    }
    if (!customElements.get('avg-link')) {
      customElements.define('avg-link', AVGLink);
    }
  
