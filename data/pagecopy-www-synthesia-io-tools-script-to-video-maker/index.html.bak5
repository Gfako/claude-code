/*Hide clones*/
[shuffle-tabs="menu-wrapper"] div[data-w-tab] {
  display: none;
}
@media only screen and (max-width: 991px) {
  /*Hide original tab pane*/
  [shuffle-tabs="content-wrapper"] {
    display: none;
  }
  /*Display active clone*/
  [shuffle-tabs="menu-wrapper"] a.w--current > div[data-w-tab] {
    display: block !important;
  }
}


.examples-tab_link-wrap.w--current {
	pointer-events: none;
}
[data-id="embla-wrapper"] {
	pointer-events: all;
}
[data-id="video-gen-examples"] .examples-tab_link-wrap.w--current [data-id="tab-heading"] {
	background-image: linear-gradient(90deg, var(--indigo-400), var(--indigo-500-main) 50%, var(--indigo-600));
	-webkit-text-fill-color: transparent;
	-webkit-background-clip: text;
}
[data-id="video-gen-examples"] .video-button[active="true"] {
	display: none;
}
[data-id="video-gen-examples"] .embla {
	padding: 0;
	margin: 0;
	position: relative;
	cursor: auto;
}
[data-id="video-gen-examples"] .embla__slide {
	border-radius: var(--border-radius-large);
	overflow: hidden;
	position: relative;
}

[data-id="video-gen-examples"] .embla__slide [data-id="examples-video-overlay"] {
	position: absolute;
  inset: -1px;
  background: linear-gradient(180deg, rgba(13, 15, 44, 0.00) 0%, rgba(13, 15, 44, 0.20) 100%);
  pointer-events: none;
  opacity: 1;
  transition: opacity .2s ease;
}
[data-id="video-gen-examples"] .embla__slide.is-playing [data-id="examples-video-overlay"] {
	opacity: 0;	
}

@media screen and (min-width: 992px) {
	[data-id="video-gen-examples"] [data-id="tab-wrapper"] {
		border-bottom-right-radius: var(--border-radius-huge);
		overflow: hidden;
	}
	[data-id="video-gen-examples"] [data-id="examples-video-container"]:last-of-type {
		border-bottom-right-radius: calc(var(--border-radius-huge) - .75rem);
		overflow: hidden;
	}
	[data-id="video-gen-examples"] [data-id='embla-wrapper'] {
		height: 100%;
	}
	[data-id="video-gen-examples"] .embla {
		height: 100%;
		display: flex;
	}
	[data-id="video-gen-examples"] [video-component],
	[data-id="video-gen-examples"] video {
		height: 100%;
	}
}
@media screen and (min-width: 768px) {
	[data-id="video-gen-examples"] .embla__container {
	  grid-column-gap: .625rem;
	  grid-row-gap: .625rem;
/*	  grid-template-rows: auto; */
/*	  grid-auto-columns: 1fr; */
	  grid-template-columns: 6fr 6fr;
	  grid-auto-rows: 1fr;
	  width: 100%;
	  display: grid;
	}
	[data-id="video-gen-examples"] [data-id="btn-group"] {
		display: none;
	}
}
@media screen and (max-width: 991px) {
	[data-id="video-gen-examples"] .w-tab-content {
		display: none !important;
	}
	.examples-tab_link-wrap:not(.w--current) > .spacer-small.show-tablet {
		display: none;
	}
		[data-id="video-gen-examples"] [data-id="tab-heading"] {
		font-size: var(--_typography---heading-tiny-font-size);
    line-height: var(--_typography---heading-tiny-line-height);
    letter-spacing: var(--_typography---heading-tiny-letter-spacing);
    text-transform: none;
    font-weight: 500;
	}
}
@media screen and (max-width: 767px) {
	[data-id="video-gen-examples"] [data-id="tab-wrapper"] {
  	margin-left: -1.25rem;
  	margin-right: -1.25rem;
    border-radius: 0 !important;
  }
  [data-id="video-gen-examples"] .embla {
		overflow: visible;
	}
	[data-id="video-gen-examples"] .embla__slide {
		min-width: 100%;
    margin-right: 2rem;
	}
	[data-id="video-gen-examples"] [data-id="btn-group"] {
		position: absolute;
		inset: 0;
		pointer-events: none !important;
	}
	[data-id="video-gen-examples"] [data-id="next-btn"],
	[data-id="video-gen-examples"] [data-id="prev-btn"] {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		pointer-events: all !important;
    min-width: 2.625rem;
    max-width: 2.625rem;
    min-height: 2.625rem;
    max-height: 2.625rem;
	}
	[data-id="video-gen-examples"] [data-id="next-btn"] {
		right: -1rem;
	}
	[data-id="video-gen-examples"] [data-id="prev-btn"] {
		left: -1rem;
	}
}
</style></div><div class="javascript w-embed w-script"><script>
document.addEventListener('DOMContentLoaded', function () {
  const CLONE_QUERY = window.matchMedia('(max-width: 991px)'); // cloning breakpoint

  // 🔹 NEW: helper – initialise any <video class="lazy"> inside a node
  function initLazyVideosIn(node) {
    if (!node || !window.initLazyVideo) return;
    if (!node.querySelectorAll) return;

    var vids = node.querySelectorAll('video.lazy');
    vids.forEach(function (v) {
      window.initLazyVideo(v);
    });
  }

  // -----------------------------
  // Clone slides for mobile rearrangement
  // -----------------------------
  function rearrangeTabs() {
    if (!CLONE_QUERY.matches) return; // only below CLONE_QUERY

    const wrapper = document.querySelector('[data-id="video-gen-examples"] [shuffle-tabs="tab-block"]');
    if (!wrapper) return;

    const menuWrapper = wrapper.querySelector('[shuffle-tabs="menu-wrapper"]');
    if (!menuWrapper) return;

    const tabs = menuWrapper.querySelectorAll('a[data-w-tab]');
    const contents = wrapper.querySelectorAll('div[data-w-tab]');

    contents.forEach((content) => {
      const tabId = content.getAttribute('data-w-tab');
      const correspondingTab = [...tabs].find(
        (tab) => tab.getAttribute('data-w-tab') === tabId
      );
      if (!correspondingTab) return;

      // Remove extra clones beyond the first, if any
      const existingClones = correspondingTab.querySelectorAll(
        `div[data-w-tab="${tabId}"]`
      );
      existingClones.forEach((clone, index) => {
        if (index > 0) clone.remove();
      });

      // If one already exists inside the tab link, skip
      if (correspondingTab.querySelector(`div[data-w-tab="${tabId}"]`)) return;

      const contentCopy = content.cloneNode(true);
      contentCopy.removeAttribute('id');
      contentCopy.querySelectorAll('[id]').forEach((child) =>
        child.removeAttribute('id')
      );
      contentCopy.setAttribute('data-cloned', tabId);

      // Always append as last child
      correspondingTab.append(contentCopy);

      // 🔹 NEW: hook cloned videos into the global lazy loader
      initLazyVideosIn(contentCopy);
    });
  }

  // Run cloning once on load (if under breakpoint)
  rearrangeTabs();

  // Re-run cloning when crossing into the mobile breakpoint for cloning
  CLONE_QUERY.addEventListener('change', (e) => {
    if (e.matches) rearrangeTabs();
    // We'll also pause videos on breakpoint changes below via shared handler.
  });

  // -----------------------------
  // EMBLA SLIDER (auto-activates only below 767px)
  // -----------------------------
  const emblaOptions = {
    active: false,           // off by default (desktop)
    loop: true,
    align: 'center',
    startIndex: 0,
    skipSnaps: false,
    watchDrag: false,
    breakpoints: {
      '(max-width: 767px)': { active: true } // auto-on for mobile
    }
  };
  
  function initEmblaRoot(root) {
    if (root.__emblaApi) return; // avoid double init
    const api = EmblaCarousel(root, emblaOptions);
    root.__emblaApi = api;
  
    // Simple nav
    const wrapper = root.closest('[data-id="embla-wrapper"]') || root.parentElement;
    const prevBtn = wrapper?.querySelector('[data-id="prev-btn"]');
    const nextBtn = wrapper?.querySelector('[data-id="next-btn"]');
    if (prevBtn) prevBtn.addEventListener('click', () => api.scrollPrev());
    if (nextBtn) nextBtn.addEventListener('click', () => api.scrollNext());
  
    // Pause videos when slide changes
    api.on('select', () => pauseAllVideos());
  }
  
  // Init all current cloned carousels once (they’ll auto-activate on mobile)
  document
    .querySelectorAll('[data-id="video-gen-examples"] [data-cloned] .embla')
    .forEach(initEmblaRoot);
  
  // If cloning produces new .embla later, init them once too
  const emblaObserver = new MutationObserver(muts => {
    muts.forEach(m => {
      m.addedNodes.forEach(node => {
        if (node.nodeType !== 1) return;
        if (node.matches?.('[data-id="video-gen-examples"] [data-cloned] .embla')) {
          initEmblaRoot(node);
        } else {
          node.querySelectorAll?.('[data-id="video-gen-examples"] [data-cloned] .embla')
            .forEach(initEmblaRoot);
        }
      });
    });
  });

  // 🔹 TWEAK: observe only the video-gen-examples section instead of document.body
  const emblaRootSection = document.querySelector('[data-id="video-gen-examples"]');
  if (emblaRootSection) {
    emblaObserver.observe(emblaRootSection, { childList: true, subtree: true });
  }

  // -----------------------------
  // VIDEO PLAYBACK (global across all sliders)
  // -----------------------------
  function pauseAllVideos() {
    document.querySelectorAll('[data-id="video-gen-examples"] .embla__slide').forEach(slide => {
      const video = slide.querySelector('video');
      const btn   = slide.querySelector('.video-button');
      if (video) video.pause();
      if (btn) btn.setAttribute('active', 'false');
      slide.classList.remove('is-playing');
    });
  }
  
  // Bind click for a single slide
  function bindSlide(slide) {
    const trigger = slide.querySelector('.expand-trigger');
    const video   = slide.querySelector('video');
    const btn     = slide.querySelector('.video-button');
    if (!trigger || !video) return;

    // (Optional, but harmless) if it's lazy, ensure it's wired:
    if (window.initLazyVideo && video.classList.contains('lazy')) {
      window.initLazyVideo(video);
    }
  
    // Toggle play/pause for this slide
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
  
      if (video.paused) {
        pauseAllVideos();
        const p = video.play();
        if (p && p.catch) p.catch(() => {}); // ignore autoplay errors
        if (btn) btn.setAttribute('active', 'true');
        slide.classList.add('is-playing');
      } else {
        video.pause();
        if (btn) btn.setAttribute('active', 'false');
        slide.classList.remove('is-playing');
      }
    });
  
    // Remove playing state when video ends or is paused
    video.addEventListener('ended', () => {
      video.currentTime = 0;
      if (btn) btn.setAttribute('active', 'false');
      slide.classList.remove('is-playing');
    });
  
    video.addEventListener('pause', () => {
      slide.classList.remove('is-playing');
    });
  
    video.addEventListener('play', () => {
      slide.classList.add('is-playing');
    });
  }
  
  // Initial bind for current slides + videos
  const section = document.querySelector('[data-id="video-gen-examples"]');
  if (section) {
    section.querySelectorAll('.embla__slide').forEach(bindSlide);
  
    // MutationObserver: bind for new slides (e.g., clones)
    const mo = new MutationObserver(muts => {
      muts.forEach(m => {
        m.addedNodes.forEach(node => {
          if (node.nodeType !== 1) return;
          if (node.classList?.contains('embla__slide')) {
            bindSlide(node);
          } else {
            node.querySelectorAll?.('.embla__slide').forEach(bindSlide);
          }
        });
      });
    });
    mo.observe(section, { childList: true, subtree: true });
  }

  // -----------------------------
  // EXTRA: Pause on tab link click
  // -----------------------------
  const tabMenu = document.querySelector('[data-id="video-gen-examples"] [shuffle-tabs="menu-wrapper"]');
  if (tabMenu) {
    tabMenu.addEventListener('click', (e) => {
      const tabLink = e.target.closest('a[data-w-tab]');
      if (tabLink) pauseAllVideos();
    });
  }

  // Also pause when the cloning breakpoint flips
  CLONE_QUERY.addEventListener('change', () => pauseAllVideos());
});
</script></div></div></section><section class="page-builder-bg-color w-variant-1aa5b3c1-5e89-1377-f72a-55c7bb9c1300" data-wf--pb-helper-background-color-w-slots--variant="indigo-100"><div><section class="padding-vertical padding-xhuge"><div class="page-padding"><div class="container-medium"><div class="text-align-center"><div><div class="caption border-indigo-300" color="" is-round="true"><div class="caption-medium">FEATURES</div></div></div><div class="spacer-xxsmall"></div><div class="text-color-base-dark"><h2 class="heading-large text-wrap-balance"><span>Why Synthesia is the best</span><span class="text-highlight-gradient"> script to video maker</span><span></span></h2></div><div class="spacer-small"></div><div class="spacer-xxlarge"></div></div></div></div><div class="flex-vertical row-gap-3-5rem row-gap-2rem-mobile-landscape"><div class="page-padding" data-id="feature-card-master" visual-inner-container=""><div class="css w-embed"><style>
