</script></div><div class="javascript w-embed w-script"><script type="module">
    (function () {
        function readCfg(rootId) {
            const root = document.querySelector(`[data-id=${rootId}]`);
            if (!root) return [];
            const out = [];
            root.querySelectorAll(':scope > [data-type="object"]').forEach(obj => {
                const code = obj.dataset.code;
                const labelEl = obj.querySelector('[data-key="label"]');
                if (labelEl) { out.push({ code, label: labelEl.textContent.trim() }); }
            });
            return out;
        }
        function buildCfgMap(langs) {
            const map = {};
            langs.forEach(({ code, label }) => {
                if (code) map[code] = label;
            });
            return map;
        }
        const widgetcfg = buildCfgMap(readCfg('widgetcfg'));
        window.__widgetcfg__ = window.__widgetcfg__ || {};
        window.__widgetcfg__ = widgetcfg;
    })();
</script></div><div class="javascript w-embed w-script"><script type="module">
    class AIVidGenWidgetGlobals {}
    AIVidGenWidgetGlobals.isIos = /iP(hone|ad|od)/i.test(navigator.userAgent);
    AIVidGenWidgetGlobals.MAX_FILE_SIZE = 100 * 1024 * 1024;
    AIVidGenWidgetGlobals.MIN_DURATION = 10;
    AIVidGenWidgetGlobals.MAX_DURATION = 30;
    AIVidGenWidgetGlobals.dimension = 'mobile-vertical';
    AIVidGenWidgetGlobals.ERROR_TEXT = {
      UI_UPLOAD_FAIL: 'Upload failed.',
      UI_UPLOAD_FAIL_FSIZE: 'Doc must be less than 100MB.',
      UI_UPLOAD_FAIL_MOD: 'Doc failed moderation.',
    };
  
    class ADComponent extends HTMLElement {
      constructor() {
        super();
      }
  
      connectedCallback() {}
  
      disconnectedCallback() {}
  
      static get observedAttributes() {
        return ['absvar'];
      }
  
      show() {
        this.style.display = 'flex';
      }
  
      hide() {
        this.style.display = 'none';
      }
  
      changeUI(state) {
        console.info(`this.changeUI: ${state}`);
        const evt = new CustomEvent(AIVidGenWidget.EVENTS_CHANGE_UI, {
          bubbles: true,
          cancelable: true,
          detail: {
            from: this,
            uiState: state,
          },
        });
        this.dispatchEvent(evt);
      }
    }
