    class AIVidGenWidget extends ADComponent {
      constructor() {
        super();
        this.serviceUrl = 'https://lxdhr7i8e0.execute-api.eu-west-1.amazonaws.com/prod';
        this.handoffurl = 'https://app.synthesia.io/#/welcome';
        this.store = this.setupStore();
        this.oldUIState = null;
        // this.currentUIState = AIVidGenWidget.UI_STATES_DEFAULT;
        this.currentUIState = AIVidGenWidget.UI_STATES_IDEA;
      }
  
      connectedCallback() {
        super.connectedCallback();
        this.AIScenesMode = Boolean(parseInt(this.dataset['scenesMode']));
        this.ideaBtn = this.querySelector('[data-id="idea-btn"]');
        this.scriptBtn = this.querySelector('[data-id="script-btn"]');
        this.urlBtn = this.querySelector('[data-id="url-btn"]');
        this.fileBtn = this.querySelector('[data-id="file-btn"]');
  
        this.uploadArea = this.querySelector('ad-uploadarea');
        this.videoThumbnail = this.querySelector('ad-videothumbnail');
        this.ideaInput = this.querySelector("[data-id='idea-input']");
        this.scriptInput = this.querySelector("[data-id='script-input']");
        this.urlLink = this.querySelector('avg-link');
        this.urlInput = this.querySelector("[data-id='url-text']");
        this.submitBtn = this.querySelector("[data-id='submit-btn']");
  
        this.errText1 = this.querySelectorAll("[data-id='error-mod']")[0];
        this.errText2 = this.querySelectorAll("[data-id='error-mod']")[1];
        this.errUrl = this.querySelector("[data-id='url-error-text']");
        this.errUpload = this.querySelector("[data-id='upload-fail-text']");
  
        this.showSamples = Boolean(parseInt(this.dataset.showSamples));
        this.defaultSampleKey = this.dataset.defaultSampleKey;
        this.defaultSource = 'idea';
        this.ogview = this.querySelector('syn-og-view');
  
        //const srcBtns = this.querySelectorAll("[data-id='src-buttons'] [data-id$='-btn']");
        // Viggo: Updating to the new wrapper
        const srcBtns = this.querySelectorAll('[data-id="vid-gen-v2-modules"] [data-id$="-btn"]');
        const srcSelected = Array.from(srcBtns).filter((btn) => {
          return btn.classList.contains('is-active');
        });
        if (srcSelected.length > 0) {
          const btn = srcSelected[0];
          btn.click();
          this.defaultSource = btn.dataset.id.split('-')[0];
        } else if (srcSelected.length == 0) {
          this.ideaBtn.click();
        }
  
        console.log(`this.defaultSource: ${this.defaultSource}`);
        console.log(`this.defaultSampleKey: ${this.defaultSampleKey}`);
  
        if (this.AIScenesMode) {
          // Viggo: Hiding this line as element is removed
          // this.querySelector("[data-id='src-buttons']").style.display = "none";
          this.querySelectorAll('[sample-els]').forEach((el) => {
            el.style.display = 'none';
          });
        }
  
        this.errText1.style.display = 'none';
        this.errText2.style.display = 'none';
        this.errUrl.style.display = 'none';
        this.errUpload.style.display = 'none';
  
        this.uploadArea.setUploadFn(this.uploadVid.bind(this));
  
        this.ideaBtn.addEventListener('click', () => {
          this.setUI(AIVidGenWidget.UI_STATES_IDEA);
        });
        this.scriptBtn.addEventListener('click', () => {
          this.setUI(AIVidGenWidget.UI_STATES_SCRIPT);
        });
        this.urlBtn.addEventListener('click', () => {
          this.setUI(AIVidGenWidget.UI_STATES_URL);
        });
        this.fileBtn.addEventListener('click', () => {
          this.setUI(AIVidGenWidget.UI_STATES_FILE);
        });
  
        this.submitBtn.addEventListener('click', async () => {
          await this.submit();
        });
  
        this.addEventListener(AIVidGenWidget.EVENTS_CHANGE_UI, (e) => {
          if (e.target.matches('aividgen-widget')) {
            const uiState = e.detail.uiState;
            console.info(`Event received from: ${e.detail.from.nodeName}, e.detail.uiState: ${e.detail.uiState}`);
            this.setUI(uiState);
          }
        });
  
        this.videoThumbnail.addEventListener(AIVidGenWidget.EVENTS_DELETE_ASSET, (e) => {
          console.log(`Heard AIVidGenWidget.EVENTS_DELETE_ASSET`);
          this.submitBtn.freeze = true;
          this.store.setKey(null);
          this.uploadArea.reset();
          this.uploadArea.show();
          this.setUI(AIVidGenWidget.UI_STATES_FILE);
        });
  
        const handleFocus = (e) => {
          this.resetErrors();
          this.checkAllowHandoff();
        };
  
        const handleInputChange = (e) => {
          this.checkAllowHandoff();
        };
  
        this.ideaInput.addEventListener('focus', handleFocus.bind(this));
        this.scriptInput.addEventListener('focus', handleFocus.bind(this));
  
        this.ideaInput.addEventListener('input', handleInputChange.bind(this));
        this.scriptInput.addEventListener('input', handleInputChange.bind(this));
        this.urlInput.addEventListener('input', handleInputChange.bind(this));
  
        const markUserEdit = (e) => {
          if (!e || e.isTrusted) this.store.sample = false;
        };
  
        this.ideaInput.addEventListener('keydown', markUserEdit);
        this.ideaInput.addEventListener('paste', markUserEdit);
        this.ideaInput.addEventListener('input', (e) => {
          if (e.isTrusted) markUserEdit(e);
        });
  
        this.scriptInput.addEventListener('keydown', markUserEdit);
        this.scriptInput.addEventListener('paste', markUserEdit);
        this.scriptInput.addEventListener('input', (e) => {
          if (e.isTrusted) markUserEdit(e);
        });
  
        this.setupDimensionChanges();
  
        Array.from(document.querySelectorAll("[data-id='inspo-btn']")).forEach((el) => {
          el.addEventListener('click', (e) => {
            this.resetErrors();
            if (e.isTrusted) {
              const sk = e.currentTarget.getAttribute('data-key');
              if (['idea-onboarding', 'idea-training', 'idea-policy'].indexOf(sk) >= 0) {
                this.store.sample = true;
                this.store.sampleKey = sk;
              } else {
                this.store.sample = false;
                // this.store.sampleKey = null;
                this.store.sampleKey = sk;
              }
  
              this.submitBtn.freeze = false;
              console.log(`this.store.sample: ${this.store.sample}, this.store.sampleKey: ${this.store.sampleKey}`);
            }
          });
        });
        
        if (this.AIScenesMode) {
          window.Webflow = window.Webflow || [];
          window.Webflow.push((_) => {
            document.querySelector("[data-id='idea-input']").value = document.querySelector("[data-id='aiscenes-sample']").textContent;
            this.submitBtn.freeze = false;
          });
        } else {
          window.Webflow = window.Webflow || [];
          window.Webflow.push((_) => {
            console.log(`window.Webflow`);
            // this.querySelector(`[data-id="${this.defaultSource}-btn"]`).click();
  
            let defaultSampleBtn = null;
  
            ///
            const activeModule = document.querySelector(`[data-id="${this.defaultSource}"]`);
            defaultSampleBtn = activeModule ? activeModule.querySelector('[data-id="inspo-btn"]') : null;
            ///
  
            // if (document.querySelector("html").getAttribute("lang") == "en") {
            //     defaultSampleBtn = this.querySelector(`[data-key='idea-20260129-onboarding']`);
            // } else {
            //     defaultSampleBtn = this.querySelector(`[data-key='${this.defaultSampleKey}']`);
            // }
  
            if (defaultSampleBtn) {
              defaultSampleBtn.click();
              this.store.sample = true;
              // this.store.sampleKey = `${this.defaultSource}-${this.defaultSampleKey}`;
              this.store.sampleKey = defaultSampleBtn.dataset.key || 'idea-onboarding';
              this.submitBtn.freeze = false;
            }
  
            // if (defaultSampleBtn) {
            //     this.store.sample = false;
            //     this.store.sampleKey = null;
            //     this.submitBtn.freeze = true;
            // }
            
            ///
            this.checkAllowHandoff();
            ///
          });
        }
  
        if (!this.showSamples) {
          Array.from(document.querySelectorAll('[sample-els]')).forEach((el) => {
            el.style.display = 'none';
          });
        }
  
        window.Webflow = window.Webflow || [];
        window.Webflow.push((_) => {
          this.checkAllowHandoff();
        });
      }
  
      disconnectedCallback() {
        super.disconnectedCallback();
      }
  
      static get observedAttributes() {
        return [...super.observedAttributes, 'instvar'];
      }
  
      attributeChangedCallback(name, oldValue, newValue) {
        const sAttrs = Object.getPrototypeOf(this.constructor).observedAttributes || [];
        if (sAttrs.indexOf(name) > -1) {
          super.attributeChangedCallback(name, oldValue, newValue);
        } else if (name === 'instvar') {
        }
      }
  
      setupStore() {
        const store = {};
        store.s3ObjKey = null;
        store.assetMode = AIVidGenWidget.ASSET_MODE_IDEA;
        store.setKey = (k) => {
          store.s3ObjKey = k;
        };
        store.getKey = () => {
          return store.s3ObjKey;
        };
        store.sample = false;
        store.sampleKey = 'idea-employee-onboarding';
        store.speakerText = null;
        store.audienceText = null;
        store.vidIds = {
          'idea-onboarding': {
            en: 'aa884dd2-3a10-40cb-ac0e-34727fc58dd4',
            fr: 'aa884dd2-3a10-40cb-ac0e-34727fc58dd4',
            de: 'aa884dd2-3a10-40cb-ac0e-34727fc58dd4',
            es: 'aa884dd2-3a10-40cb-ac0e-34727fc58dd4',
            'pt-br': 'aa884dd2-3a10-40cb-ac0e-34727fc58dd4',
          },
          'idea-training': {
            en: '50dd7595-1e59-4c55-8db6-34744b1c93a3',
            fr: '50dd7595-1e59-4c55-8db6-34744b1c93a3',
            de: '50dd7595-1e59-4c55-8db6-34744b1c93a3',
            es: '50dd7595-1e59-4c55-8db6-34744b1c93a3',
            'pt-br': '50dd7595-1e59-4c55-8db6-34744b1c93a3',
          },
          'idea-policy': {
            en: '4ddffe15-8028-4f42-a6cd-9b4f92b55a3e',
            fr: '4ddffe15-8028-4f42-a6cd-9b4f92b55a3e',
            de: '4ddffe15-8028-4f42-a6cd-9b4f92b55a3e',
            es: '4ddffe15-8028-4f42-a6cd-9b4f92b55a3e',
            'pt-br': '4ddffe15-8028-4f42-a6cd-9b4f92b55a3e',
          },
  
          'script-youtube': {
            en: '',
            fr: '',
            de: '',
            es: '',
            'pt-br': '',
          },
          'script-product': {
            en: '',
            fr: '',
            de: '',
            es: '',
            'pt-br': '',
          },
          'script-travel': {
            en: '',
            fr: '',
            de: '',
            es: '',
            'pt-br': '',
          },
        };
        return store;
      }
  
      setupDimensionChanges() {
        const getView = (_) => {
          const w = window.innerWidth;
          const landscape = window.matchMedia('(orientation: landscape)').matches;
          if (w >= 992) return 'desktop';
          if (w >= 768) return 'tablet';
          return landscape ? 'mobile-horizontal' : 'mobile-vertical';
        };
  
        const dimChanged = (_) => {
          AIVidGenWidgetGlobals.dimension = getView();
          switch (AIVidGenWidgetGlobals.dimension) {
            case 'desktop':
              break;
            case 'tablet':
              break;
            case 'mobile-horizontal':
              break;
            case 'mobile-vertical':
              break;
          }
        };
  
        dimChanged();
  
        window.addEventListener('resize', dimChanged.bind(this));
        const mqOrient = window.matchMedia('(orientation: landscape)');
        if (mqOrient.addEventListener) {
          mqOrient.addEventListener('change', dimChanged.bind(this));
        } else if (mqOrient.addListener) {
          mqOrient.addListener(dimChanged.bind(this));
        }
      }
  
      checkAllowHandoff() {
        switch (this.currentUIState) {
          case AIVidGenWidget.UI_STATES_IDEA:
            if (this.ideaInput.value) {
              this.submitBtn.freeze = false;
            } else {
              this.submitBtn.freeze = true;
            }
            break;
          case AIVidGenWidget.UI_STATES_SCRIPT:
            if (this.scriptInput.value) {
              this.submitBtn.freeze = false;
            } else {
              this.submitBtn.freeze = true;
            }
            break;
          case AIVidGenWidget.UI_STATES_URL:
            if (this.urlLink.isValid) {
              this.submitBtn.freeze = false;
            } else {
              this.submitBtn.freeze = true;
            }
            break;
          case AIVidGenWidget.UI_STATES_FILE:
            if (this.store.getKey()) {
              this.submitBtn.freeze = false;
            } else {
              this.submitBtn.freeze = true;
            }
            break;
          case AIVidGenWidget.UI_STATES_UPLOAD_SUCCESS:
            if (this.store.getKey()) {
              this.submitBtn.freeze = false;
            } else {
              this.submitBtn.freeze = true;
            }
            break;
        }
      }
  
      async setUI(state) {
        console.info(`setUI, oldUIState: ${this.oldUIState}, current: ${this.currentUIState}`);
        this.oldUIState = this.currentUIState;
        switch (state) {
          case AIVidGenWidget.UI_STATES_DEFAULT:
            this.submitBtn.freeze = true;
            this.store.sample = false;
            this.resetErrors();
            break;
          case AIVidGenWidget.UI_STATES_IDEA:
            this.submitBtn.freeze = true;
            this.ideaInput.value = '';
            this.store.assetMode = AIVidGenWidget.ASSET_MODE_IDEA;
            this.store.sample = false;
            this.store.sampleKey = null; //Addition because of below commented out part
            this.resetErrors();
            /*
                  let ideaPreset = null;
                  if (document.querySelector("html").getAttribute("lang") == "en") {
                      ideaPreset = document.querySelector(`[data-key='idea-20260129-onboarding']`);
                  } else {
                      ideaPreset = document.querySelector(`[data-key='idea-${this.defaultSampleKey}']`);
                  }
                  if (ideaPreset) {
                      ideaPreset.click();
                      this.store.sample = true;
                      this.store.sampleKey = `idea-${this.defaultSampleKey}`;
                  }
                  */
            break;
          case AIVidGenWidget.UI_STATES_SCRIPT:
            this.submitBtn.freeze = true;
            this.scriptInput.value = '';
            this.store.assetMode = AIVidGenWidget.ASSET_MODE_SCRIPT;
            this.store.sample = false;
            this.store.sampleKey = null; //Addition because of below commented out part
            this.resetErrors();
            /*
                  const scriptPreset = document.querySelector(`[data-key='script-${this.defaultSampleKey}']`);
                  if (scriptPreset) {
                      scriptPreset.click();
                      this.store.sample = true;
                      this.store.sampleKey = `script-${this.defaultSampleKey}`;
                  }
                  */
            break;
          case AIVidGenWidget.UI_STATES_URL:
            if (this.ogview) this.ogview.hide();
            this.submitBtn.freeze = true;
            this.urlLink.reset();
            this.store.assetMode = AIVidGenWidget.ASSET_MODE_URL;
            this.store.sample = false;
            this.resetErrors();
            break;
          case AIVidGenWidget.UI_STATES_FILE:
            this.submitBtn.freeze = true;
            this.store.setKey(null);
            this.uploadArea.reset();
            this.uploadArea.show();
            this.store.assetMode = AIVidGenWidget.ASSET_MODE_FILE;
            this.store.sample = false;
            this.resetErrors();
            break;
          case AIVidGenWidget.UI_STATES_UPLOAD_SUCCESS:
            this.checkAllowHandoff();
            break;
          case AIVidGenWidget.UI_STATES_UPLOAD_FAIL:
            this.submitBtn.freeze = true;
            this.videoThumbnail.hasErrored(true);
            break;
          case AIVidGenWidget.UI_STATES_SUBMIT_FAIL:
            console.log(`AIVidGenWidget.UI_STATES_SUBMIT_FAIL`);
            this.submitBtn.freeze = false;
            break;
          case AIVidGenWidget.UI_STATES_SUBMIT:
            const result = deviceDetect();
            const { isBrowser, isMobile, isTablet, isSmartTV, isConsole, isWearable, osName, browserName } = result;
            const isDevice = isMobile ? true : false;
  
            let url = null;
            let evtId = null;
            let inputContent = null;
            switch (this.store.assetMode) {
              case AIVidGenWidget.ASSET_MODE_IDEA:
                url = `${this.handoffurl}?assistant=1&type=idea&mode=work&assetId=${encodeURIComponent(this.store.getKey())}`;
                evtId = 'Work';
                inputContent = this.ideaInput.value;
                break;
              case AIVidGenWidget.ASSET_MODE_SCRIPT:
                // url = `${this.handoffurl}?assistant=1&type=script&mode=creative&assetId=${encodeURIComponent(this.store.getKey())}`;
                url = `${this.handoffurl}?assistant=1&type=idea&mode=creative&assetId=${encodeURIComponent(this.store.getKey())}`;
                evtId = 'Creative';
                inputContent = this.scriptInput.value;
                break;
              case AIVidGenWidget.ASSET_MODE_URL:
                url = `${this.handoffurl}?assistant=1&type=url&url=${encodeURIComponent(this.urlInput.value)}`;
                evtId = 'Url';
                inputContent = this.urlInput.value;
                break;
              case AIVidGenWidget.ASSET_MODE_FILE:
                inputContent = document.querySelectorAll('[data-id="upload-name"]')[0].textContent;
                if (inputContent.search('ppt') >= 0 || inputContent.search('pptx') >= 0) {
                  if (isDevice) {
                    url = `${this.handoffurl}?assistant=1&type=file&assetId=${encodeURIComponent(this.store.getKey())}`;
                  } else {
                    url = `${this.handoffurl}?ppt=1&type=file&assetId=${encodeURIComponent(this.store.getKey())}`;
                    url = `${url}&import=true&convert=true`;
                  }
                } else {
                  url = `${this.handoffurl}?assistant=1&type=file&assetId=${encodeURIComponent(this.store.getKey())}`;
                }
                evtId = `File`;
                break;
            }
  
            const lang = document.querySelector('html').getAttribute('lang');
  
            if (this.store.sample) {
              console.log(`Do Sample, this.store.sampleKey: ${this.store.sampleKey}`);
              url = `${this.handoffurl}?assistant=1&exampleVideoId=${this.store.vidIds[this.store.sampleKey][lang.toLowerCase()]}`;
            }
  
            switch (lang) {
              case 'fr':
                url = `${url}&language=fr-FR`;
                break;
              case 'de':
                url = `${url}&language=de-DE`;
                break;
              case 'es':
                url = `${url}&language=es-ES`;
                break;
              case 'pt-BR':
                url = `${url}&language=pt-PT`;
                break;
              default:
                url = `${url}&language=en-001`;
                break;
            }
  
            if (this.AIScenesMode) {
              url = `${url}&clips=1`;
            }
  
            const getSlug = (href) => new URL(href).pathname.split('/').filter(Boolean).pop();
            const slug = getSlug(document.querySelector('link[rel="alternate"][hreflang="x-default"]').href).replace(/-/g, '_');
            if (slug) {
              url = `${url}&pageSource=${slug}`;
            }
  
            if (this.store.speakerText) {
              const paramSpeaker = new URLSearchParams({
                speaker: this.store.speakerText,
              });
  
              url = `${url}&${paramSpeaker.toString()}`;
            }
            if (this.store.audienceText) {
              const paramAudience = new URLSearchParams({
                audience: this.store.audienceText,
              });
  
              url = `${url}&${paramAudience.toString()}`;
            }
  
            const go = (_) => {
              document.location.href = url;
            };
            try {
                let sampleKey = this.store.sampleKey;
                if (sampleKey == "idea-policy") {
                    sampleKey = "idea-marketing";
                }
                if (sampleKey == "script-product") {
                    sampleKey = "script-fitness";
                }

                let is_preset = this.store.sample;
                console.log(`1: is_preset: ${is_preset}`);
                if (evtId.toLowerCase() == 'creative') {
                    if (['script-youtube', 'script-fitness', 'script-travel'].indexOf(sampleKey) >= 0) {
                        is_preset = true;
                        console.log(`2: is_preset: ${is_preset}`);
                    }
                }

              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'video_generator_submit',
                input_type: evtId,
                is_preset: is_preset,
                // payload_text: inputContent,
                eventCallback: (c) => {
                  console.log(`fired, ${evtId}, ${is_preset}, ${inputContent}, ${c}`);
                  setTimeout(go, 1000);
                },
                eventTimeout: 2000,
              });
              setTimeout(go, 5000);
            } catch (e) {
              console.log('Err.');
              go();
            }
            break;
        }
        this.currentUIState = state;
      }
  
      resetErrors() {
        this.errText1.style.display = 'none';
        this.errText2.style.display = 'none';
        this.errUrl.style.display = 'none';
        this.errUpload.style.display = 'none';
        this.videoThumbnail.hasErrored(false);
      }
  
      tellUploadFailed(t = AIVidGenWidget.UI_STATES_UPLOAD_FAIL) {
        switch (t) {
          case AIVidGenWidget.UI_STATES_UPLOAD_FAIL_FSIZE:
            this.errUpload.style.display = 'flex';
            break;
          case AIVidGenWidget.UI_STATES_UPLOAD_FAIL_MOD:
            this.errUpload.style.display = 'flex';
            break;
          case AIVidGenWidget.UI_STATES_UPLOAD_FAIL:
            this.errUpload.style.display = 'flex';
            break;
          case AIVidGenWidget.UI_STATES_SUBMIT_FAIL:
            this.errText1.style.display = 'flex';
            this.errText2.style.display = 'flex';
            this.errUrl.style.display = 'flex';
            break;
          case AIVidGenWidget.UI_STATES_SUBMIT_FAIL_MOD:
            this.errText1.style.display = 'flex';
            this.errText2.style.display = 'flex';
            this.errUrl.style.display = 'flex';
            break;
        }
        if (t !== AIVidGenWidget.UI_STATES_SUBMIT_FAIL_MOD) {
          this.setUI(t);
        }
      }
  
      async uploadVid(file, progressGfx) {
        const API_URL = this.serviceUrl;
        const CHUNK_SIZE = 5 * 1024 * 1024;
  
        this.resetErrors();
  
        if (file.size > AIVidGenWidgetGlobals.MAX_FILE_SIZE) {
          console.error(`> ${AIVidGenWidgetGlobals.MAX_FILE_SIZE}`);
          this.tellUploadFailed(AIVidGenWidget.UI_STATES_UPLOAD_FAIL_FSIZE);
          return false;
        }
  
        try {
          const initiateResponse = await fetch(`${API_URL}/upload/start`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              filename: file.name,
              size: file.size,
              contentType: file.type,
              assetmode: this.store.assetMode,
            }),
          });
          const { uploadId, key } = await initiateResponse.json();
  
          const partETags = [];
          const totalParts = Math.ceil(file.size / CHUNK_SIZE);
  
          for (let partNumber = 1; partNumber <= totalParts; partNumber++) {
            const start = (partNumber - 1) * CHUNK_SIZE;
            const end = Math.min(start + CHUNK_SIZE, file.size);
            const blobPart = file.slice(start, end);
  
            const presignResponse = await fetch(`${API_URL}/upload/${uploadId}/part/${partNumber}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ key }),
            });
            const { url } = await presignResponse.json();
  
            await this.uploadPart(url, blobPart, partNumber, totalParts, partETags, progressGfx);
          }
  
          const completeResponse = await fetch(`${API_URL}/upload/${uploadId}/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key, parts: partETags }),
          });
  
          if (completeResponse.ok) {
            const { mod_ok } = await completeResponse.json();
            console.info(`Uploaded, mod_ok: ${mod_ok}`);
            if (!mod_ok) {
              this.tellUploadFailed(AIVidGenWidget.UI_STATES_UPLOAD_FAIL_MOD);
            } else {
              this.store.setKey(key);
              this.videoThumbnail.setAsset(file);
              this.changeUI(AIVidGenWidget.UI_STATES_UPLOAD_SUCCESS);
            }
          } else {
            try {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'video_generator_upload_failed_mod',
              });
            } catch (e) {}
            this.tellUploadFailed(AIVidGenWidget.UI_STATES_UPLOAD_FAIL_MOD);
            return false;
          }
        } catch (error) {
          console.error('Err during upload:', error);
          try {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'video_generator_upload_failed',
            });
          } catch (e) {}
          this.tellUploadFailed(AIVidGenWidget.UI_STATES_UPLOAD_FAIL);
          return false;
        }
      }
  
      uploadPart(presignedUrl, blobPart, partNumber, totalParts, partETags, progressGfx) {
        const uploadProgress = document.querySelector('[data-id="upload-progress"]');
        return new Promise((resolve, reject) => {
          const xhr = new XMLHttpRequest();
          xhr.open('PUT', presignedUrl, true);
          xhr.setRequestHeader('Content-Type', 'application/octet-stream');
  
          xhr.upload.onprogress = (event) => {
            if (event.lengthComputable) {
              const completeValue = (partNumber - 1 + event.loaded / event.total) / totalParts;
              if (progressGfx) {
                progressGfx.setValue(completeValue);
              }
            }
          };
  
          xhr.onload = () => {
            if (xhr.status === 200) {
              const eTag = xhr.getResponseHeader('ETag');
              partETags.push({ PartNumber: partNumber, ETag: eTag });
              resolve();
            } else {
              reject(new Error(`Upload failed with status ${xhr.status}`));
            }
          };
  
          xhr.onerror = () => reject(new Error('Network error during upload'));
  
          xhr.send(blobPart);
        });
      }
  
      async submit() {
        this.submitBtn.freeze = true;
        if (this.store.sample && document.querySelector('html').getAttribute('lang') == 'en') {
          this.changeUI(AIVidGenWidget.UI_STATES_SUBMIT);
          return;
        }
        if (this.store.assetMode == AIVidGenWidget.ASSET_MODE_FILE) {
          this.changeUI(AIVidGenWidget.UI_STATES_SUBMIT);
          return;
        }
  
        let payload = {
          mode: 'MODE_TEXT',
        };
        switch (this.store.assetMode) {
          case AIVidGenWidget.ASSET_MODE_IDEA:
            payload['input_text'] = this.ideaInput.value;
            payload['tab'] = "🏢";
            break;
          case AIVidGenWidget.ASSET_MODE_SCRIPT:
            payload['input_text'] = this.scriptInput.value;
            payload['tab'] = "🎨";
            break;
          case AIVidGenWidget.ASSET_MODE_URL:
            payload['mode'] = 'MODE_URL';
            payload['input_url'] = this.urlInput.value;
            break;
        }
        try {
          const resp = await fetch(`${this.serviceUrl}/submit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (resp.ok) {
            switch (this.store.assetMode) {
              case AIVidGenWidget.ASSET_MODE_IDEA:
                const { key } = await resp.json();
                this.store.setKey(key);
                break;
              case AIVidGenWidget.ASSET_MODE_SCRIPT:
                const keyy = (await resp.json())['key'];
                this.store.setKey(keyy);
                break;
              case AIVidGenWidget.ASSET_MODE_URL:
                //
                break;
            }
            this.changeUI(AIVidGenWidget.UI_STATES_SUBMIT);
          } else {
            const content = `${this.ideaInput.value} ${this.scriptInput.value} ${this.urlInput.value}`;
            const mod = await resp.json();
            console.log(`content: ${content}, mod: ${JSON.stringify(mod)}`);
            try {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'video_generator_moderation_flagged',
                payload_text: content,
                flagged_words: JSON.stringify(mod),
              });
            } catch (e) {}
            this.tellUploadFailed(AIVidGenWidget.UI_STATES_SUBMIT_FAIL_MOD);
            return false;
          }
        } catch (error) {
          console.error('Err:', error);
          this.tellUploadFailed(AIVidGenWidget.UI_STATES_SUBMIT_FAIL);
          return false;
        }
      }
    }
    AIVidGenWidget.ASSET_MODE_IDEA = 'MODE_IDEA';
    AIVidGenWidget.ASSET_MODE_SCRIPT = 'MODE_SCRIPT';
    AIVidGenWidget.ASSET_MODE_URL = 'MODE_URL';
    AIVidGenWidget.ASSET_MODE_FILE = 'MODE_FILE';
  
    AIVidGenWidget.EVENTS_CHANGE_UI = 'EVT_CHANGE_UI';
    AIVidGenWidget.EVENTS_DELETE_ASSET = 'EVT_DELETE_ASSET';
  
    AIVidGenWidget.UI_STATES_DEFAULT = 'UI_DEFAULT';
    AIVidGenWidget.UI_STATES_IDEA = 'UI_IDEA';
    AIVidGenWidget.UI_STATES_SCRIPT = 'UI_SCRIPT';
    AIVidGenWidget.UI_STATES_URL = 'UI_URL';
    AIVidGenWidget.UI_STATES_FILE = 'UI_FILE';
  
    AIVidGenWidget.UI_STATES_UPLOAD_SUCCESS = 'UI_UPLOAD_SUCCESS';
    AIVidGenWidget.UI_STATES_UPLOAD_FAIL = 'UI_UPLOAD_FAIL';
    AIVidGenWidget.UI_STATES_UPLOAD_FAIL_FSIZE = 'UI_UPLOAD_FAIL_FSIZE';
    AIVidGenWidget.UI_STATES_UPLOAD_FAIL_MOD = 'UI_UPLOAD_FAIL_MOD';
    AIVidGenWidget.UI_STATES_SUBMIT_FAIL = 'UI_SUBMIT_FAIL';
    AIVidGenWidget.UI_STATES_SUBMIT_FAIL_MOD = 'UI_SUBMIT_FAIL_MOD';
    AIVidGenWidget.UI_STATES_LINK_SUCCESS = 'UI_LINK_SUCCESS';
    AIVidGenWidget.UI_STATES_LINK_INVALID = 'UI_LINK_INVALID';
    AIVidGenWidget.UI_STATES_SUBMIT = 'UI_SUBMIT';
    if (!customElements.get('aividgen-widget')) {
      customElements.define('aividgen-widget', AIVidGenWidget);
    }
  </script></div><div class="javascript w-embed w-script"><script data-id="djs-additions" type="module">
    const run = _ => {
        const widget = document.querySelector("aividgen-widget");
        const showTabs = Boolean(parseInt(widget.querySelector("[data-show-tabs]").dataset.showTabs));
        const showOptions = Boolean(parseInt(widget.querySelector("[data-show-options]").dataset.showOptions));
        const speakerEl = widget.querySelector("[data-id='speaker-text']")
        const audienceEl = widget.querySelector("[data-id='audience-text']")

        if (!showTabs) {
            widget.querySelector("[data-show-tabs]").style.display = "none";
            widget.querySelector("[data-show-tabs]").classList.add("hide");
        }

        if (showOptions) {
            widget.querySelector("[data-show-options]").classList.remove("hide");
        }
        
        speakerEl.addEventListener("input", e => {
            widget.store.speakerText = speakerEl.value;
            widget.store.sample = false;
        });
        audienceEl.addEventListener("input", e => {
            widget.store.audienceText = audienceEl.value;
            widget.store.sample = false;
        });

        const toggle = document.querySelector('[data-id="options-toggle"]');
        const wrapper = document.querySelector('[data-id="options-wrapper"]');

        toggle.addEventListener('click', () => {
            wrapper.classList.toggle('open');
            toggle.classList.toggle('open');
        });

        const ogview = widget.querySelector("syn-og-view");

        widget.addEventListener("UI_LINK_SUCCESS", e => {
            console.log(`AIVidGenWidget.UI_STATES_LINK_SUCCESS: ${e.detail.from.urlText.value}`);
            ogview.url = e.detail.from.urlText.value
        });

        widget.addEventListener("UI_LINK_INVALID", _ => {
            console.log("AIVidGenWidget.UI_STATES_LINK_INVALID");
            ogview.hide();
        });
    }
  
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run);
    } else {
        run();
    }
</script></div></section><aividgen-widget data-auto-focus="1" data-default-sample-key="employee-onboarding" data-scenes-mode="0" data-show-samples="1"><div class="position-relative" data-id="video-gen-form"><div class="video-gen_container is-vid-gen-v2"><div data-id="vid-gen-v2-modules"><div class="flex" data-id="tab-container" style="display:none"><div class="flex-child-grow" data-id="idea-btn" data-tab-link="work"><div class="marketing-icon is-grey"><div class="icon-24 w-embed"><svg fill="none" height="24" viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
