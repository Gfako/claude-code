document.addEventListener("DOMContentLoaded", function () {
  const widget = document.querySelector("aividgen-widget");
  const workBgs = document.querySelectorAll('[data-id="bg-work"]');
  const creativeBgs = document.querySelectorAll('[data-id="bg-creative"]');

  if (!widget || !workBgs.length || !creativeBgs.length) return;

  function updateBackground() {
    const mode = widget.getAttribute("data-active-src");

    workBgs.forEach(el => el.classList.toggle("is-active", mode === "idea"));
    creativeBgs.forEach(el => el.classList.toggle("is-active", mode === "script"));
  }

  // Run once on load
  updateBackground();

  // Watch for changes
  const observer = new MutationObserver(updateBackground);
  observer.observe(widget, {
    attributes: true,
    attributeFilter: ["data-active-src"]
  });
});
</script></div><div class="w-embed"><style>

  [data-id='bg-work'],
  [data-id='bg-creative'] {
    display: none;
  }
    [data-id='bg-work'].is-active,
  [data-id='bg-creative'].is-active {
    display: block;
  }
  
  .caption[data-id='ai-vid-gen'] {
    background:
      linear-gradient(#1a1e41, #1a1e41) padding-box,
      linear-gradient(90deg, #5969b1 0%, #2e3e96 100%) border-box;
    border: 1px solid transparent;
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.5);
    color: var(--indigo-300);
    align-items: center;
  }

  @media screen and (min-width: 768px) {
    @keyframes floating {
      0% {
        transform: translate(0%, 0%);
      }
      25% {
        transform: translate(15%, 7.5%);
      }
      50% {
        transform: translate(0%, 15%);
      }
      75% {
        transform: translate(-15%, 7.5%);
      }
      100% {
        transform: translate(0%, 0%);
      }
    }

    [data-id='bg-work'] .overflow-hidden,
    [data-id='bg-creative'] .overflow-hidden {
      display: contents;
    }

    [data-id='bg-work'] video,
    [data-id='bg-work'] img:not(.background-cover-image),
    [data-id='bg-creative'] video,
    [data-id='bg-creative'] img:not(.background-cover-image) {
      position: absolute;
      height: auto;
      border-radius: var(--border-radius-xlarge);
      pointer-events: none;
    }

    [data-id='bg-work'] > div:nth-of-type(1) video,
    [data-id='bg-work'] > div:nth-of-type(1) img {
      top: -210px;
      left: -440px;
      width: 275px;
      filter: blur(3px);
      animation: floating 14s ease-in-out infinite;
    }
    [data-id='bg-work'] > div:nth-of-type(2) video,
    [data-id='bg-work'] > div:nth-of-type(2) img {
      top: -210px;
      right: -400px;
      width: 365px;
      animation: floating 18s ease-in-out infinite reverse;
    }
    [data-id='bg-work'] > div:nth-of-type(3) video,
    [data-id='bg-work'] > div:nth-of-type(3) img {
      bottom: 230px;
      left: -190px;
      width: 136px;
      filter: blur(2px);
      animation: floating 16s ease-in-out infinite;
      animation-delay: -6s;
    }
    [data-id='bg-work'] > div:nth-of-type(4) video,
    [data-id='bg-work'] > div:nth-of-type(4) img {
      bottom: -50px;
      left: -270px;
      width: 400px;
      animation: floating 16s ease-in-out infinite;
      animation-delay: -6s;
    }
    /*Replace with still image*/
    [data-id='bg-work'] > div:nth-of-type(5) video,
    [data-id='bg-work'] > div:nth-of-type(5) img {
      bottom: 64px;
      right: -250px;
      width: 114px;
      filter: blur(5px);
      animation: floating 12s ease-in-out infinite;
      animation-delay: -4s;
    }

    [data-id='bg-creative'] > div:nth-of-type(1) video,
    [data-id='bg-creative'] > div:nth-of-type(1) img {
      top: -210px;
      left: -440px;
      width: 396px;
      filter: blur(4px);
      opacity: 0.6;
      animation: floating 14s ease-in-out infinite;
    }
    [data-id='bg-creative'] > div:nth-of-type(2) video,
    [data-id='bg-creative'] > div:nth-of-type(2) img {
      top: -210px;
      right: -410px;
      width: 378px;
      animation: floating 18s ease-in-out infinite reverse;
    }
    [data-id='bg-creative'] > div:nth-of-type(3) video,
    [data-id='bg-creative'] > div:nth-of-type(3) img {
      bottom: -50px;
      left: -270px;
      width: 306px;
      background:
        linear-gradient(#000000, #000000) padding-box,
        linear-gradient(45deg, #8098f9, #f6b2ec, #00cee0) border-box;
      border: 2px solid transparent;
      animation: floating 16s ease-in-out infinite;
      animation-delay: -6s;
    }
    /*Replace with still image*/
    [data-id='bg-creative'] > div:nth-of-type(4) video,
    [data-id='bg-creative'] > div:nth-of-type(4) img {
      bottom: -175px;
      right: -210px;
      width: 190px;
      animation: floating 12s ease-in-out infinite;
      animation-delay: -4s;
    }
  }

  @media screen and (max-width: 767px) {
    [data-id='bg-work'].hide-mobile-landscape,
    [data-id='bg-creative'].hide-mobile-landscape {
      display: none !important;
    }
  }

  html.wf-design-mode [data-id='bg-work'] video,
  html.wf-design-mode [data-id='bg-work'] img,
  html.wf-design-mode [data-id='bg-creative'] video,
  html.wf-design-mode [data-id='bg-creative'] img {
    animation-play-state: paused !important;
  }
  @media screen and (max-width: 767px) {
    [data-id='bg-creative'] .show-mobile-landscape video {
      object-position: center;
      max-height: 100%;
    }
  }
</style></div></div></header></div><section class="padding-vertical padding-xhuge" data-id="video-gen-examples"><div class="page-padding"><div class="container-large"><div class="position-relative"><div class="text-align-center"><div class="caption border-indigo-300" color="" is-round="true"><div class="caption-medium">Examples</div></div><div class="spacer-small"></div><h2 class="heading-large text-color-base-dark"><span>Create any type of video from your script in</span><span class="text-highlight-gradient"> minutes</span><span> with AI</span></h2><div class="spacer-xsmall"></div><div class="container-small"><div class="rich-text-large w-richtext"><p>From product explainers to YouTube video explainers, product walkthroughs, and feature announcements — Synthesia’s AI video generator gives you everything to produce stunning videos from a script with lifelike AI avatars and cinematic B-roll.</p></div></div><div class="spacer-xxxlarge hide-tablet"></div><div class="spacer-xxlarge is-fixed show-tablet"></div></div><div class="border-radius-large background-indigo is-100" data-id="tab-wrapper"><div class="padding-xxsmall"><div class="grid-12col-base gap-075rem w-tabs" data-current="Tab 1" data-duration-in="300" data-duration-out="100" data-easing="ease" shuffle-tabs="tab-block"><div class="flex-vertical flex-gap-025rem w-tab-menu" id="w-node-_0d39e89b-6ab6-239e-2cd8-079c3bd3df37-3bd3df1f" shuffle-tabs="menu-wrapper"><a class="examples-tab_link-wrap w-inline-block w-tab-link w--current" data-w-tab="Tab 1"><h3 class="paragraph-large is-medium text-color-base-dark" data-id="tab-heading">Avatar Videos</h3><div class="spacer-tiny"></div><p class="label-regular" target="item-description">Create lifelike videos with AI presenters that speak any script.</p><div class="spacer-small show-tablet"></div></a><a class="examples-tab_link-wrap w-inline-block w-tab-link" data-w-tab="Tab 2"><h3 class="paragraph-large is-medium text-color-base-dark" data-id="tab-heading">Sora 2 Videos</h3><div class="spacer-tiny"></div><p class="label-regular" target="item-description">Generate video clips from text prompts with Sora 2.</p><div class="spacer-small show-tablet"></div></a><a class="examples-tab_link-wrap w-inline-block w-tab-link" data-w-tab="Tab 3"><h3 class="paragraph-large is-medium text-color-base-dark" data-id="tab-heading">Veo 3 Videos</h3><div class="spacer-tiny"></div><p class="label-regular" target="item-description">Write prompts to produce cinematic videos with Veo 3.</p><div class="spacer-small show-tablet"></div></a><a class="examples-tab_link-wrap w-inline-block w-tab-link" data-w-tab="Tab 4"><h3 class="paragraph-large is-medium text-color-base-dark" data-id="tab-heading">Stock Library</h3><div class="spacer-tiny"></div><p class="label-regular" target="item-description">Access thousands of royalty-free videos and images - no watermarks.</p><div class="spacer-small show-tablet"></div></a><a class="examples-tab_link-wrap w-inline-block w-tab-link" data-w-tab="Tab 5"><h3 class="paragraph-large is-medium text-color-base-dark" data-id="tab-heading">Video Templates</h3><div class="spacer-tiny"></div><p class="label-regular" target="item-description">Use professionally designed templates to start creating videos quickly.</p><div class="spacer-small show-tablet"></div></a></div><div class="w-tab-content" id="w-node-_0d39e89b-6ab6-239e-2cd8-079c3bd3df5b-3bd3df1f"><div class="position-relative w-tab-pane w--tab-active" data-id="embla-wrapper" data-w-tab="Tab 1"><div class="embla"><div class="embla__container"><div class="embla__slide" data-id="examples-video-container"><div class="expand-trigger is-centered"><div active="false" button-size="" class="video-button" white="false"><div class="video-button_inner"><img alt="" class="icon-16 video-button_play" loading="lazy" src="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/65f866078eb05892fc20795a_Play-white.svg"/><img alt="" class="icon-16 video-button_pause" loading="lazy" src="https://