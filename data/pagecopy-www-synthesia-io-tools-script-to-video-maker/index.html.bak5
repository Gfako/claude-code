</svg></div><div class="caption-small text-highlight-gradient is-indigo-light">#1 AI Video platform for business</div></div><div class="z-3"><div class="spacer-xsmall"></div><h1 class="heading-large"><span>Free </span><span class="text-highlight-gradient is-indigo-light">AI Script to Video </span><span>Maker</span></h1><div class="spacer-xsmall"></div><p class="paragraph-small">Input your script and generate a studio-quality video in minutes. Save time and budget. No editing skills required.</p><div class="spacer-medium"></div></div></div><div class="max-width-fit-content margin-auto position-relative"><section class="width-50rem max-width-100-percent align-center" data-hide-sticky-cta="" data-id="aivg-widget"><div class="css w-embed"><style>
  .video-gen_container.is-vid-gen-v2 {
    border: none;
  }
  ad-button#video-gen-submit[freeze] {
    opacity: 0.2;
    pointer-events: none;
  }

  [data-id='idea'],
  [data-id='script'],
  [data-id='url'] {
    flex-direction: column;
  }

  /*Inputs*/
  [data-id='vid-gen-v2-modules'] textarea,
  [data-id='vid-gen-v2-modules'] input {
    padding: 0;
    border-radius: 0;
    border: none;
    box-shadow: none !important;
    color: var(--grey-700);
    min-height: 6.625rem;
  }
  [data-id='vid-gen-v2-modules'] textarea {
    min-height: 6.625rem;
  }

  [data-id='vid-gen-v2-modules'] textarea:focus-visible,
  [data-id='vid-gen-v2-modules'] input:focus-visible {
    outline: none !important;
  }
  [data-id='vid-gen-v2-modules'] textarea::placeholder,
  [data-id='vid-gen-v2-modules'] input::placeholder {
    color: var(--grey-500);
  }


  /*Scroll snap*/
  [data-scroll='container'] {
    margin: 0 -1rem;
    padding: 0 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 1rem;
    -ms-overflow-style: none;
    scrollbar-width: none;
    position: relative;
  }
  [data-scroll='item'] {
    scroll-snap-align: start;
  }

  /*Fade*/
  [data-id='fade-left'],
  [data-id='fade-right'] {
    position: absolute;
    top: -3px;
    bottom: -3px;
    z-index: 9;
    width: 1rem;
    pointer-events: none;
  }
  [data-id='fade-left'] {
    right: 100%;
    background-image: linear-gradient(90deg, white 10%, transparent);
  }
  [data-id='fade-right'] {
    left: 100%;
    background-image: linear-gradient(-90deg, white 10%, transparent);
  }

  /*Tabs*/
  [data-id='vid-gen-v2-modules'] [data-id='tab-container'] {
    overflow: hidden;
    border-top-left-radius: var(--border-radius-xlarge);
    border-top-right-radius: var(--border-radius-xlarge);
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link] {
    position: relative;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--grey-300);
    background: white;
    cursor: pointer;
    display: grid;
    grid-column-gap: 0.5rem;
    grid-row-gap: 0rem;
    grid-template-rows: auto auto;
    grid-template-columns: auto 1fr;
  }

  [data-id='vid-gen-v2-modules'] [data-tab-link] .marketing-icon {
    grid-area: span 2 / span 1 / span 2 / span 1;
    align-self: center;
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link] [data-id='tab-description'] {
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
  @media screen and (min-width: 480px) {
    [data-id='vid-gen-v2-modules'] [data-tab-link] [data-id='tab-headline'] {
      margin-bottom: -2px;
    }
    [data-id='vid-gen-v2-modules'] [data-tab-link] [data-id='tab-description'] {
      margin-top: -2px;
    }
  }
  @media screen and (max-width: 479px) {
    [data-id='vid-gen-v2-modules'] [data-tab-link] {
      grid-column-gap: 0.375rem;
    }
    [data-id='vid-gen-v2-modules'] [data-tab-link] .marketing-icon {
      grid-row: span 1 / span 1;
      max-width: 1rem;
      max-height: 1rem;
      align-self: center;
      border-radius: 0.1875rem;
    }
    [data-id='vid-gen-v2-modules'] [data-tab-link] .marketing-icon .icon-24 {
      width: 0.75rem;
      height: 0.75rem;
      padding: 0;
    }
    [data-id='vid-gen-v2-modules'] [data-tab-link] [data-id='tab-description'] {
      grid-area: span 1 / span 2 / span 1 / span 2;
      font-size: 0.625rem;
    }
  }

  [data-id='vid-gen-v2-modules'] [data-tab-link].is-active {
    position: relative;
    z-index: 2;
    box-shadow: 0 0 16px 0 rgba(13, 15, 44, 0.15);
    transition: 0.2s ease;
    transition-property: color, background, box-shadow;
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='work'].is-active {
    background: linear-gradient(90deg, #ffffff, #e3ebff);
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='creative'].is-active {
    background: linear-gradient(-90deg, #ffffff, #e3ebff);
  }

  [data-id='vid-gen-v2-modules'] [data-tab-link] [data-id='active-tab-border'] {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  html.wf-design-mode [data-tab-link] [data-id='active-tab-border'] {
    display: none;
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='work'] [data-id='active-tab-border'] {
    background: linear-gradient(90deg, #c6d7fe, #8098f9, #c8faff, #c6d7fe);
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='creative'] [data-id='active-tab-border'] {
    background: linear-gradient(90deg, #c6d7fe, #8098f9, #ff9478, #f6b2ec, #c6d7fe);
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link].is-active [data-id='active-tab-border'] {
    opacity: 1;
  }

  [data-id='vid-gen-v2-modules'] [data-tab-link]:hover .opacity-60,
  [data-id='vid-gen-v2-modules'] [data-tab-link].is-active .opacity-60 {
    opacity: 1;
    color: var(--indigo-500-main);
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='work']:hover .marketing-icon,
  [data-id='vid-gen-v2-modules'] [data-tab-link='work'].is-active .marketing-icon {
    background: linear-gradient(45deg, #08a9c7, #243278 40%, #5d71c7);
    color: white;
  }
  [data-id='vid-gen-v2-modules'] [data-tab-link='creative']:hover .marketing-icon,
  [data-id='vid-gen-v2-modules'] [data-tab-link='creative'].is-active .marketing-icon {
    background: linear-gradient(45deg, #4057d9, #ad449e 40%, #e599da);
    color: white;
  }

  /*File and URL buttons*/
  /*Hide on creative tab*/
  aividgen-widget[data-active-src='script'] [data-id='file-btn'] {
    display: none;
  }
  [data-id='vid-gen-v2-modules'] [data-id='cta-bar'] {
    display: flex;
    gap: 0.75rem;
  }
  ad-button#video-gen-submit {
    margin-left: auto;
  }
  @media screen and (max-width: 479px) {
    ad-button#video-gen-submit {
      margin-left: 0;
      flex-grow: 1;
    }
  }

  /*
[data-id="cta-bar"] .w-dropdown {
	margin: 0;
}
[data-id="cta-bar"] .w-dropdown-list {
	background: transparent;
}
@media screen and (min-width: 480px) {
  [data-id="cta-bar"] .w-dropdown-toggle {
		display: none;
	}
	[data-id="cta-bar"] .w-dropdown-list {
		display: flex;
		gap: .75rem;
		position: relative;
	}
}
@media screen and (max-width: 479px) {
  [data-id="cta-bar"] ad-button {
		flex-grow: 1;
	}
	[data-id="cta-bar"] .w-dropdown-toggle {
		height: 100%;
		width: 2.5rem;
		padding: 0;
	}
	[data-id="cta-bar"] .w-dropdown-toggle.button-secondary:focus,
	[data-id="cta-bar"] .w-dropdown-toggle.w--open.button-secondary {
		box-shadow: 0 0 0 1px var(--grey-300),0 6px 20px 0 var(--shadow);
		background-color: var(--grey-200);
	}
	
	[data-id="cta-bar"] .w-dropdown-toggle .icon-16 {
		transform: none !important;
	}
	[data-id="cta-bar"] .w-dropdown-list {
		background: white;
		border: 1px solid var(--grey-300);
		border-radius: var(--border-radius-small);
		box-shadow: 0 4px 16px 0 var(--shadow);
		overflow: hidden;
		width: 9.625rem;
    margin-top: .25rem;
	}
	[data-id="cta-bar"] .w-dropdown-list .button-secondary {
		background: white;
		border: none !important;
		box-shadow: none !important;
		border-radius: 0;
		padding: .75rem;
		justify-content: flex-start;
	}
	[data-id="cta-bar"] .w-dropdown-list .button-secondary:hover {
		background: var(--indigo-100);
	}
}
*/

  /*Inspo buttons*/
  .badge[data-id='inspo-btn'] {
    background: transparent;
    color: var(--grey-700);
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--indigo-300);
    cursor: pointer;
    transition: 0.2s ease;
    transition-property: border-color, background;
  }
  .badge[data-id='inspo-btn']:hover {
    background: var(--indigo-100);
    border-color: var(--indigo-500-main);
  }

  /*Upload modules*/
  ad-uploadarea,
  [data-id='url'] {
    min-height: 11.875rem;
  }

  [data-id='drop-area'] {
    position: relative;
    display: flex;
    min-width: 100%;
    min-height: 100%;
    padding: 1rem 0.75rem;
    justify-content: center;
    align-items: center;
    align-self: stretch;
    cursor: pointer;
    background-color: var(--grey-100);
    border-radius: 0.5rem;
    border: 1px dashed var(--grey-200);
    transition: background-color 0.3s ease;
  }
  [data-id='drop-area']:hover,
  [data-id='drop-area'].dragover {
    background-color: var(--grey-200);
  }
  [data-id='drop-area'] [data-id='upload-close-btn'] {
    position: absolute;
    z-index: 999;
    top: 0;
    right: 0;
    cursor: pointer;
  }
  [data-id='drop-area'] [data-id='upload-close-btn']:hover .icon-12 {
    color: var(--base-dark) !important;
  }
  /*Doc icons*/
  [data-id='upload-img-container'],
  [data-id='upload-img-container'] img {
    height: 3.25rem;
    aspect-ratio: 3 / 4;
  }
  [data-id='upload-img-container'] img {
    position: absolute;
    filter: drop-shadow(0px 1px 1.5px rgba(0, 0, 0, 0.08));
    transform-origin: bottom;
    transition: transform 0.3s ease-out;
  }
  [data-id='upload-img-container'] [data-id='upload-img-1'] {
    top: 0;
    right: -0.25rem;
    z-index: 2;
  }
  [data-id='upload-img-container'] [data-id='upload-img-2'] {
    bottom: 0;
    left: -0.25rem;
    transform: rotate(-5deg);
  }
  [data-id='drop-area']:hover [data-id='upload-img-1'],
  [data-id='drop-area'].dragover [data-id='upload-img-1'] {
    transform: rotate(5deg);
  }
  [data-id='drop-area']:hover [data-id='upload-img-2'],
  [data-id='drop-area'].dragover [data-id='upload-img-2'] {
    transform: rotate(-10deg);
  }

  /*Thumbnails modules*/
  ad-videothumbnail {
    min-width: 100%;
  }
  [data-id="upload-name"] {
    word-break: break-all;
  }
  [data-id='upload-result'],
  [data-id='uploading'] {
    width: 100%;
    height: 100%;
    padding: 1.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: var(--border-radius-small);
    border: 1px solid var(--grey-200);
    background: white;
  }
  [data-id='uploading'] {
    border: 1px dashed var(--grey-200);
  }
  [data-id='upload-result'] [data-id='file-delete-btn'] {
    cursor: pointer;
    transition: color 0.2s ease;
  }
  [data-id='upload-result'] [data-id='file-delete-btn']:hover {
    color: var(--error-600-main);
  }
  [data-id='file-upload-progress'] {
    height: 0.25rem;
    width: 100%;
    margin-top: 0.5rem;
    background-color: var(--grey-200);
    border-radius: var(--border-radius-full);
    overflow: hidden;
  }
  [data-id='file-upload-progress-bar'] {
    height: 100%;
    width: auto;
    background-color: var(--indigo-500-main);
    border-radius: var(--border-radius-full);
    max-width: 0%;
    transition: max-width 0.2s linear;
  }
</style></div><div class="javascript w-embed w-script"><script data-id="djs-ui" type="module">
  const run = (_) => {
    const widget = document.querySelector('aividgen-widget');
    //const btnContainer = document.querySelector('[data-id="src-buttons"]');
    const btnContainer = document.querySelector('[data-id="vid-gen-v2-modules"]');

    //const ctaWrapper = document.querySelector('[data-id="cta-bar-option-wrapper"]');

    const autoFocus = Boolean(parseInt(widget.dataset.autoFocus));

    const srcButtons = {
      idea: btnContainer.querySelector('[data-id="idea-btn"]'),
      script: btnContainer.querySelector('[data-id="script-btn"]'),
      url: btnContainer.querySelector('[data-id="url-btn"]'),
      file: btnContainer.querySelector('[data-id="file-btn"]'),
    };

    const modules = {
      idea: document.querySelector('[data-id="idea"]'),
      script: document.querySelector('[data-id="script"]'),
      url: document.querySelector('[data-id="url"]'),
      file: document.querySelector('[data-id="file-upload"]'),
    };

    const uploadCloseBtn = widget.querySelector('[data-id="upload-close-btn"]');
    if (uploadCloseBtn) {
      uploadCloseBtn.addEventListener('click', (e) => {
        e.stopPropagation(); // prevents dropArea click
        e.preventDefault();

        srcButtons.idea?.click(); // Programatic click on idea tab
      });
    }

    // Hide all modules initially
    function hideAllModules() {
      Object.values(modules).forEach((module) => {
        module.style.display = 'none';
      });
    }

    // Show one module and focus its textarea or input
    function showModule(key) {
      hideAllModules();
      if (modules[key]) {
        modules[key].style.display = 'flex';

        const textarea = modules[key].querySelector('textarea');
        const input = modules[key].querySelector('input');

        if (textarea) {
          if (autoFocus) {
            textarea.focus();
          }
        } else if (input) {
          if (autoFocus) {
            input.focus();
          }
        }
      }
    }

    // Button activation and module switching
    /*
        Object.entries(srcButtons).forEach(([key, button]) => {
            button.addEventListener("click", () => {
                Object.values(srcButtons).forEach(btn => btn.classList.remove("is-active"));
                button.classList.add("is-active");
                showModule(key);
            });
        });
        */
    const activeKeys = ['idea', 'script'];

    Object.entries(srcButtons).forEach(([key, button]) => {
      if (!button) return;

      button.addEventListener('click', () => {
        if (activeKeys.includes(key)) {
          activeKeys.forEach((k) => srcButtons[k]?.classList.remove('is-active'));
          button.classList.add('is-active');

          // ✅ single source of truth for “which is active”
          widget.setAttribute('data-active-src', key);
        }

        /*
            if (ctaWrapper) {
              if (key === "script") {
                ctaWrapper.style.visibility = "hidden";
              } else if (key === "idea") {
                ctaWrapper.style.visibility = "visible";
              }
            }
            */

        showModule(key);
      });
    });

    // Character counter setup
    function setupCharCounter(moduleKey) {
      const module = modules[moduleKey];
      const textarea = module.querySelector('textarea');
      const charSpan = module.querySelector(`[data-id="${moduleKey}-char"]`);
      const inputContainer = module.querySelector(`[data-id="${moduleKey}-input-container"]`);

      if (!textarea || !charSpan || !inputContainer) return;

      function updateCharCount() {
        const currentLength = textarea.value.length;
        const maxLength = parseInt(textarea.getAttribute('maxlength'), 10);
        charSpan.textContent = currentLength;

        if (maxLength && currentLength >= maxLength) {
          inputContainer.classList.add('max-chars');
        } else {
          inputContainer.classList.remove('max-chars');
        }
      }

      textarea.addEventListener('input', updateCharCount);
      updateCharCount();

      return textarea;
    }

    // Inspiration button setup
    function setupInspoButtons(moduleKey, textarea) {
      const module = modules[moduleKey];
      let inspoBtnsWrapper = null;
      if (moduleKey === 'idea') {
        inspoBtnsWrapper = module.querySelector('[data-id="2026-idea-samples"]');
        // inspoBtnsWrapper = module.querySelector('[data-id="inspo-btns"]');
      } else {
        inspoBtnsWrapper = module.querySelector('[data-id="inspo-btns"]');
      }

      if (!inspoBtnsWrapper || !textarea) return;

      // const buttons = inspoBtnsWrapper.querySelectorAll('[data-id="inspo-btn"]');
      const buttons = document.querySelectorAll('[data-id="inspo-btn"]');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const key = button.getAttribute('data-key');

          let html = null;
          let content = null;

          if (key.match('idea-20260129')) {
            html = window.__widgetcfg__[key];
            if (!html) return;
            content = html.trim();
          } else {
            const contentEl = document.querySelector(`[data-id="inspo-content"][data-key="${key}"]`);

            if (!contentEl) return;

            html = contentEl.innerHTML;
            content = html
              .replace(/<br\s*\/?>/gi, '\n')
              .replace(/&nbsp;/gi, ' ')
              .replace(/&amp;/gi, '&')
              .trim();
          }

          textarea.value = content;
          if (autoFocus) {
            textarea.focus();
          }
          //textarea.setSelectionRange(0, 0); // Move caret to the start
          //textarea.scrollTop = 0;           // Scroll to top of textarea
          textarea.dispatchEvent(new Event('input'));
        });
      });
    }

    // Expand textarea button setup
    /*
        function setupExpandButton(moduleKey) {
            const module = modules[moduleKey];
            const expandBtn = module.querySelector('[data-id="expand-textarea"]');
            const inputContainer = module.querySelector(`[data-id="${moduleKey}-input-container"]`);

            if (!expandBtn || !inputContainer) return;

            expandBtn.addEventListener("click", () => {
                inputContainer.classList.toggle("expanded");
            });
        }
        */

    // Setup all modules
    const ideaTextarea = setupCharCounter('idea');
    const scriptTextarea = setupCharCounter('script');

    setupInspoButtons('idea', ideaTextarea);
    setupInspoButtons('script', scriptTextarea);

    //setupExpandButton("idea");
    //setupExpandButton("script");

    // Initial load: show idea module
    // srcButtons.idea.click();

    // Initial load: resolve which button to click
    // const buttons = Object.values(srcButtons).filter(Boolean);
    // const actives = buttons.filter(btn => btn.classList.contains("is-active"));

    // if (actives.length === 1) {
    // Exactly one active -> honor it
    // actives[0].click();
    // } else {
    // None or multiple actives -> prefer idea, then any active, then first available
    // (srcButtons.idea || actives[0] || buttons[0])?.click();
    // }

    if (document.querySelector('html').getAttribute('lang') == 'en') {
    } else {
      document.querySelector('[data-id="2026-idea-samples"]').style.display = 'none';
      document.querySelector('[data-id="inspo-btns"]').classList.remove('hide');
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
</script></div><div class="css w-embed"><style>
    html.wf-design-mode [data-id='idea-samples'],
    html.wf-design-mode [data-id='script-samples'],
    html.wf-design-mode [data-id='idea'],
    html.wf-design-mode [data-id='script'],
    html.wf-design-mode [data-id='url'],
    html.wf-design-mode [data-id='file-upload'],
    html.wf-design-mode [data-id='error-mod'],
    html.wf-design-mode [data-id="ad-videothumbnail"],
    html.wf-design-mode [data-show-options],
    html.wf-design-mode [dataid="idea-samples"] {
        display: flex !important;
        flex-direction: column;
    }

    html.wf-design-mode .sr-only {
        clip: auto !important;
        white-space: normal !important;
        width: auto !important;
        height: auto !important;
        margin: 0 !important;
        padding: 1rem;
        position: relative !important;
        overflow: visible !important;
    }

    html.wf-design-mode .sr-only [data-key="label"] {
        font-family: 'Courier New', Courier, monospace;
        color: #000;
        background-color: var(--success-400);
        padding: 0.5rem;
        margin-bottom: 1rem;
    }
</style></div><section><div class="javascript w-embed w-script"><script>
