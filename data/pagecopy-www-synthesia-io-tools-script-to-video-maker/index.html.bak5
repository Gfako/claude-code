rod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb379deca61966a86a_marketing-video-p-1080.png 1080w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb379deca61966a86a_marketing-video-p-1600.png 1600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb379deca61966a86a_marketing-video.png 1920w"/></div><div class="spacer-xxxsmall"></div><div class="label-medium text-align-center text-style-nowrap text-style-1line">Marketing video</div></div></div><div class="border-radius-small background-white" data-id="inspo-btn" data-key="idea-20260129-cavern"><div class="padding-xxxsmall"><div class="border-radius-xxsmall aspect-ratio-16-9 display-flex"><img alt="" class="width-height-100-percent object-fit-cover" loading="lazy" sizes="100vw" src="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run.png" srcset="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run-p-500.png 500w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run-p-800.png 800w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run-p-1080.png 1080w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run-p-1600.png 1600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb4c8b0e13f405d32a_frozen-ice-cavern-run.png 1920w"/></div><div class="spacer-xxxsmall"></div><div class="label-medium text-align-center text-style-nowrap text-style-1line">Frozen ice cavern run</div></div></div><div class="border-radius-small background-white" data-id="inspo-btn" data-key="idea-20260129-training"><div class="padding-xxxsmall"><div class="border-radius-xxsmall aspect-ratio-16-9 display-flex"><img alt="" class="width-height-100-percent object-fit-cover" loading="lazy" sizes="100vw" src="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video.png" srcset="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video-p-500.png 500w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video-p-800.png 800w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video-p-1080.png 1080w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video-p-1600.png 1600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaebcac0077cffdd0dd3_training-video.png 1920w"/></div><div class="spacer-xxxsmall"></div><div class="label-medium text-align-center text-style-nowrap text-style-1line">Training video</div></div></div><div class="border-radius-small background-white" data-id="inspo-btn" data-key="idea-20260129-alley"><div class="padding-xxxsmall"><div class="border-radius-xxsmall aspect-ratio-16-9 display-flex"><img alt="" class="width-height-100-percent object-fit-cover" loading="lazy" sizes="100vw" src="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley.png" srcset="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley-p-500.png 500w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley-p-800.png 800w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley-p-1080.png 1080w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley-p-1600.png 1600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/697caaeb1fc792f2c0729fd0_neon-lit_Chinatown_alley.png 1920w"/></div><div class="spacer-xxxsmall"></div><div class="label-medium text-align-center text-style-nowrap text-style-1line">Neon-lit Chinatown alley</div></div></div></div><div data-id="fade-left"></div><div data-id="fade-right"></div><div class="javascript w-embed w-script"><script data-id="djs-ideas" type="module">
    const run = _ => {
        const widget = document.querySelector("aividgen-widget");
        // const toggle = document.querySelector('[data-id="toggle"]');
        const landscapeWrap = widget.querySelector('[data-id="2026-idea-samples"] [data-id="template-landscape"]');
        // const portraitWrap = widget.querySelector('[data-id="template-portrait"]');

        // if (!toggle || !landscapeWrap || !portraitWrap) return; // fail-safe

        // --- Helpers ------------------------------------------------------------
        const allTemplateCards = () => widget.querySelector("[data-id='2026-idea-samples']").querySelectorAll('[data-id="inspo-btn"]');

        function selectTemplate(card) {
            // Remove selection everywhere, then select the clicked one
            allTemplateCards().forEach(el => el.classList.remove('selected'));
            card.classList.add('selected');
            // Accessibility attribute
            allTemplateCards().forEach(el =>
                el.setAttribute('aria-selected', el.classList.contains('selected') ? 'true' : 'false')
            );
        }

        // function showWrapper(wrapperToShow, wrapperToHide) {
        //     wrapperToShow.style.display = 'flex';
        //     wrapperToHide.style.display = 'none';
        // }

        // function clickFirstTemplate(wrapper) {
        //     const firstCard = wrapper.querySelector('[data-id="inspo-btn"]');
        //     if (firstCard) firstCard.click();
        // }

        // --- Attach click listeners directly to template cards ------------------
        allTemplateCards().forEach(card => {
            card.addEventListener('click', () => selectTemplate(card));
        });

        // --- Toggle behavior ----------------------------------------------------
        // function applyToggleState() {
        //     if (toggle.checked) {
        //         // Portrait mode
        //         showWrapper(portraitWrap, landscapeWrap);
        //         clickFirstTemplate(portraitWrap);
        //     } else {
        //         // Landscape mode
        //         showWrapper(landscapeWrap, portraitWrap);
        //         clickFirstTemplate(landscapeWrap);
        //     }
        // }

        // toggle.addEventListener('change', applyToggleState);

        // --- Initial state ------------------------------------------------------
        // portraitWrap.style.display = 'none';
        // applyToggleState(); // ensures initial wrapper + selection

        ///

        // const widget = document.querySelector("aividgen-widget");

        // --- tiny throttle (local so we don't depend on anything else)
        const throttle = (fn, wait = 100) => {
            let t = 0, lastArgs, frame;
            return function throttled(...args) {
                lastArgs = args;
                const now = Date.now();
                if (now - t >= wait) {
                    t = now; fn.apply(this, lastArgs);
                } else {
                    cancelAnimationFrame(frame);
                    frame = requestAnimationFrame(() => {
                        if (Date.now() - t >= wait) { t = Date.now(); fn.apply(this, lastArgs); }
                    });
                }
            };
        };

        // center a child inside a horizontally scrolling container
        function centerChild(container, child, behavior = 'smooth') {
            if (!container || !child) return;
            // if hidden (e.g., display:none) defer until visible
            const isHidden = container.clientWidth === 0 || container.offsetParent === null;
            if (isHidden) return;

            const childCenter = child.offsetLeft + child.offsetWidth / 2;
            const target = Math.max(0, childCenter - container.clientWidth / 2);
            container.scrollTo({ left: target, behavior });
        }

        function findSelected(container) {
            return container.querySelector(
                '[data-id="inspo-btn"].selected, [data-id="inspo-btn"][aria-selected="true"]'
            );
        }

        function setupTemplateScroller(container) {
            if (!container) return;

            const wrappers = container.querySelectorAll('[data-id="inspo-btn"]');
            const centerSelected = (behavior = 'smooth') => {
                centerChild(container, findSelected(container), behavior);
            };

            // Initial center (use 'auto' to avoid an initial animation jump)
            centerSelected('auto');

            // Observe selection changes on each card (class or aria-selected)
            const cardObserver = new MutationObserver((mutations) => {
                for (const m of mutations) {
                    if (m.type === 'attributes' && (m.attributeName === 'class' || m.attributeName === 'aria-selected')) {
                        // Only react if this card became selected
                        const el = m.target;
                        const isSelected = el.classList.contains('selected') || el.getAttribute('aria-selected') === 'true';
                        if (isSelected) centerSelected();
                    }
                }
            });
            wrappers.forEach(w => cardObserver.observe(w, { attributes: true, attributeFilter: ['class', 'aria-selected'] }));

            // If the whole strip toggles visibility (e.g., portrait hidden then shown), recenter when it becomes visible
            const visibilityObserver = new MutationObserver(() => {
                // once visible, center without animation to avoid jumpy UX
                if (container.clientWidth > 0 && container.offsetParent !== null) centerSelected('auto');
            });
            visibilityObserver.observe(container, { attributes: true, attributeFilter: ['style', 'class'] });

            // Recenter on resize (throttled)
            const onResize = throttle(() => centerSelected('auto'), 120);
            window.addEventListener('resize', onResize);

            // Optional: if your code programmatically scrolls or alters layout, you can call centerSelected() again.
            return {
                disconnect: () => {
                    cardObserver.disconnect();
                    visibilityObserver.disconnect();
                    window.removeEventListener('resize', onResize);
                }
            };
        }

        // Wire up both strips independently
        const landscape = widget.querySelector("[data-id='2026-idea-samples']").querySelector('[data-id="template-landscape"]');
        // const portrait = widget.querySelector('[data-id="template-portrait"]');
        setupTemplateScroller(landscape);
        // setupTemplateScroller(portrait);
    };
    
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run);
    } else {
        run();
    }
</script></div></div><div class="hide" data-id="idea-samples"><div data-id="inspo-content" data-key="idea-onboarding">Create a short, friendly onboarding welcome video for a new team member.</div><div data-id="inspo-content" data-key="idea-training">Create a short training video that explains fundamentals of creating and maintaining secure passwords.</div><div data-id="inspo-content" data-key="idea-policy">Create a promotional marketing video for a fictional productivity tool called Synergy Flow.</div></div></div><div class="padding-xsmall" data-id="script" style="display:block"><div class="position-relative"><div class="flex flex-gap-075rem" data-id="inspo-btns" data-scroll="container" sample-els=""><div class="badge" data-id="inspo-btn" data-key="script-youtube" data-scroll="item"><div class="icon-12 w-embed"><svg fill="none" height="12" viewbox="0 0 12 12" width="12" xmlns="http://www.w3.org/2000/svg">
