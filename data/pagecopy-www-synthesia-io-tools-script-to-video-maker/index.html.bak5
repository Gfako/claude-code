</svg></div></a><a button="" class="button-secondary is-small is-stretched w-inline-block" data-id="nav-cta" data-wf-ao-click-engagement-tracking="true" data-wf-component-context="%5B%7B%22componentId%22%3A%22f38f524c-bf5b-007e-7b31-2059396b9c3c%22%2C%22instanceId%22%3A%223a727070-d01f-7f45-1a18-d29f89f6ac9c%22%7D%5D" data-wf-element-id="243c8fac-f230-ef3b-fab9-6e6811b37ed9" data-wf-native-id-path="3a727070-d01f-7f45-1a18-d29f89f6ac9c:243c8fac-f230-ef3b-fab9-6e6811b37ed9" href="/book-a-demo" show-tablet="true"><div>Book demo</div></a></div></div></div><div class="show-tablet"><div class="z-9999"><div class="flex flex-centre-align flex-gap-1-5rem"><div class="hide-mobile-landscape"><a class="button is-small is-stretched w-inline-block" data-id="nav-cta" data-wf-ao-click-engagement-tracking="true" data-wf-component-context="%5B%7B%22componentId%22%3A%22f38f524c-bf5b-007e-7b31-2059396b9c3c%22%2C%22instanceId%22%3A%223a727070-d01f-7f45-1a18-d29f89f6ac9c%22%7D%5D" data-wf-element-id="243c8fac-f230-ef3b-fab9-6e6811b37ee0" data-wf-native-id-path="3a727070-d01f-7f45-1a18-d29f89f6ac9c:243c8fac-f230-ef3b-fab9-6e6811b37ee0" href="/pricing"><div>Get started</div></a></div><div class="navbar_burger-icon-wrapper" data-id="nav-mobile-menu-toggle"><div class="navbar_burger-menu-stroke"></div><div class="navbar_burger-menu-stroke"></div><div class="navbar_burger-menu-stroke"></div></div></div></div></div></div><div class="component-code"><div class="navbar-styling w-embed"><style>
  @media screen and (max-width: 767px) {
    /* Change position of navbar based on js class adding*/
    .navbar:not(.is-open).navbar-hidden {
      top: -4.5rem !important;
    }
    /* Change position of sticky section based on js class adding*/
    .navbar-hidden-sticky[data-sticky-section] {
      top: 0rem !important;
    }
  }

  /* Default position of sticky sections */
  [data-sticky-section] {
    top: 4.475rem !important;
    transition: top 0.3s ease-out;
  }
  /* Transition for nav hide/show */
  #nav {
    transition: 0.3s ease-out;
    transition-property: background-color, box-shadow, top;
  }
  .navbar[scrolled='true'],
  .navbar:not([variant='light'], [variant='dark']) {
    box-shadow: 0 2px 16px 0 var(--shadow);
  }
  /* Fixes for Safari bugs*/
  .navbar {
    transform: translate(0rem);
  }
  /* No linebreak on navbar items */
  .navbar_dropdown-toggle {
    white-space: nowrap !important;
  }

  @media screen and (max-width: 991px) {
    /*Open mobile menu */
    .navbar.is-open .navbar_content-wrapper {
      top: 0vh;
    }
    /*Set menu items to display none when menu is closed, to lazy load assets*/
    .navbar:not(.is-open) .navbar_dropdown-wrapper {
      display: none !important;
    }
    .navbar_dropdown-wrapper {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows .3s ease-in-out;
    }
    .navbar_dropdown-wrapper.w--open {
      display: grid;
      grid-template-rows: 1fr;
    }
  }

  /* Hide book a demo link and divider on smaller desktops */
  @media screen and (max-width: 1050px) {
    .navbar_hide-desktop-custom {
      display: none;
    }
  }

  @media screen and (min-width: 992px) {
    /* custom font size on top level links */
    .navbar_dropdown-toggle .paragraph-medium {
      font-size: 0.9375rem;
      letter-spacing: -0.00375rem;
    }
    /*custom icon size on top level links*/
    .navbar_dropdown-toggle .icon-16 {
      width: 0.625rem;
      height: 0.625rem;
    }
    .navbar_dropdown-locale-list-item-wrapper .paragraph-medium {
      font-size: 0.875rem;
      line-height: 1.375rem;
      letter-spacing: -0.00175rem;
    }
  }

  @media screen and (max-width: 991px) {
    /* Change small buttons to large in mobile menu*/
    .navbar_cta-container .button.is-small:not(.synthesia-tooltip.is-language-popup .button.is-small),
    .navbar_cta-container .button-secondary.is-small {
      letter-spacing: -0.004rem;
      padding: 0.75rem 1.125rem;
      font-size: 1rem;
      line-height: 1.5rem;
      border-radius: var(--border-radius-small);
    }
  }

  /* START - BURGER MENU TRANSITION */
  .navbar.is-open .navbar_burger-icon-wrapper .navbar_burger-menu-stroke:nth-child(1) {
    transform: translateY(0.5rem) rotate(45deg);
  }
  .navbar.is-open .navbar_burger-icon-wrapper .navbar_burger-menu-stroke:nth-child(2) {
    opacity: 0;
  }
  .navbar.is-open .navbar_burger-icon-wrapper .navbar_burger-menu-stroke:nth-child(3) {
    transform: translateY(-0.5rem) rotate(-45deg);
  }
  /* END - BURGER MENU TRANSITION */

  /* START - LOCALES DROPDOWN */
  /* Hide tick on all locales except current */
  .navbar_dropdown-locale-list-wrapper .navbar_dropdown-locale-list-item-wrapper:not(.w--current) .icon-12 {
    visibility: hidden;
  }

  @media screen and (max-width: 991px) {
    .position-relative[lang-selector] {
      min-width: 100%;
    }
  }
  /* Only display current locales iso code on mobile menu*/
  .navbar_locale-dropdown-toggle-text a:not(.w--current) {
    display: none;
  }

  .navbar_locale-dropdown-toggle:hover {
    color: var(--indigo-500-main);
  }

  /* END - LOCALES DROPDOWN */

  /* START - MENU DROPDOWNS*/
  /*Transition for desktop dropdowns*/
  @media screen and (min-width: 991px) {
    .navbar_dropdown-wrapper {
      display: none;
      -webkit-animation: close-dd 0.2s;
      animation: close-dd 0.2s;
    }
    .navbar_dropdown-wrapper.w--open {
      display: block;
      -webkit-animation: open-dd 0.2s;
      animation: open-dd 0.2s;
    }
    @-webkit-keyframes open-dd {
      from {
        opacity: 0;
        transform: translateX(-0.5rem);
      }
      to {
        opacity: 1;
        transform: translateX(0rem);
      }
    }
    @keyframes open-dd {
      from {
        opacity: 0;
        transform: translateX(-0.5rem);
      }
      to {
        opacity: 1;
        transform: translateX(0rem);
      }
    }
    @-webkit-keyframes close-dd {
      from {
        display: block;
        opacity: 1;
        transform: translateX(0rem);
      }
      to {
        display: none;
        opacity: 0;
        transform: translateX(-0.5rem);
      }
    }
    @keyframes close-dd {
      from {
        display: block;
        opacity: 1;
        transform: translateX(0rem);
      }
      to {
        display: none;
        opacity: 0;
        transform: translateX(-0.5rem);
      }
    }
    .navbar_bg-overlay.is-visible {
      opacity: 20%;
      pointer-events: all;
    }
  }

  /*Rotate dropdown toggle icon when open */
  .navbar_dropdown-toggle.w--open .icon-16 {
    transform: rotate(180deg);
  }

  /* START - LINKS BOLD ON HOVER */
  /* Position hidden pseudo element center-aligned below navlink */
  .navbar_dropdown-toggle .paragraph-medium {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    transition: color 0.2s ease;
  }
  /* Style dropdown link on hover */
  .navbar_dropdown-element-wrapper:hover .navbar_dropdown-toggle {
    font-weight: 500;
    color: var(--indigo-500-main);
  }
  /* Add hidden element with same styling as link on hover */
  .navbar_dropdown-toggle .paragraph-medium:after {
    display: inline-block;
    content: attr(title);
    letter-spacing: 0.01em;
    font-weight: 500;
    overflow: hidden;
    visibility: hidden;
    height: 0px;
  }
  /* END - LINKS BOLD ON HOVER */

  /* START - VARIANTS STYLING */
  .navbar_mobile-container {
    transition:
      background-color 0.3s ease-in-out,
/*      border-bottom-color 0.3s ease-in-out; */
  }
  .navbar[variant='dark'],
  .navbar[variant='light'] {
    background-color: #ffffff00;
  }
  .navbar[variant='dark']:hover,
  .navbar[variant='light']:hover {
    background-color: #ffffff10;
  }
  .navbar[variant='dark']:not(.is-open) .navbar_mobile-container,
  .navbar[variant='light']:not(.is-open) .navbar_mobile-container {
    background-color: #ffffff00;
    border-bottom-color: transparent;
  }
  .navbar[variant='dark']:not(.is-open) .navbar_logo-white {
    display: block;
  }
  .navbar[variant='dark']:not(.is-open) .navbar_burger-menu-stroke {
    background-color: white;
  }
  .navbar[variant='dark']:not(.is-open) .navbar_logo-dark {
    display: none;
  }
  @media screen and (min-width: 991px) {
    .navbar[variant='dark'] .navbar_dropdown-toggle,
    .navbar[variant='dark'] .navbar_locale-dropdown-toggle {
      color: #ffffff;
    }
    .navbar[variant='dark'] .navbar_dropdown-element-wrapper:hover .navbar_dropdown-toggle,
    .navbar[variant='dark'] .navbar_locale-dropdown-toggle:hover {
      color: var(--indigo-300);
    }
  }
  .navbar[variant='dark']:not(.is-open) .button:not(.synthesia-tooltip.is-language-popup .button) {
    background-color: var(--base-white);
    box-shadow:
      0 0 0 1px var(--grey-300),
      0 2px 10px 0 var(--shadow);
    color: var(--base-dark);
  }
  .navbar[variant='dark']:not(.is-open) .button:not(.synthesia-tooltip.is-language-popup .button):hover {
    background-color: var(--grey-200);
    box-shadow:
      0 0 0 1px var(--grey-300),
      0 6px 20px 0 var(--shadow);
  }
  nav[variant='dark'] .divider[vertical='true'] {
    opacity: 40%;
  }
  /* END - VARIANTS STYLING */

  /*White border on marketing icon in item card*/
  .navbar_dd-menu-item-card .marketing-icon {
    box-shadow: 0 0 0 2px white;
  }
  .navbar .badge {
    padding: 0 0.5rem;
  }
  .navbar .badge .label-medium {
    font-size: 0.625rem;
  }

  @media screen and (min-width: 992px) {
    /*Dislay tab content and active states for tabs*/
    [dd-team]:not([dd-team='active']),
    [dd-use-case]:not([dd-use-case='active']),
    [dd-industry]:not([dd-industry='active']) {
      display: none;
    }
    [dd-team-tab='active'],
    [dd-use-case-tab='active'],
    [dd-industry-tab='active'] {
      background: var(--indigo-100);
    }
    [dd-team-tab='active'] .icon-12.opacity-0,
    [dd-use-case-tab='active'] .icon-12.opacity-0,
    [dd-industry-tab='active'] .icon-12.opacity-0 {
      opacity: 1;
    }
    [dd-team-tab='active'] .marketing-icon,
    [dd-use-case-tab='active'] .marketing-icon,
    [dd-industry-tab='active'] .marketing-icon {
      background: var(--indigo-500-main);
      color: white;
    }
    /*Hover state on tab icon*/
    .navbar_dd-navigation-tab:hover .marketing-icon {
      background-color: var(--indigo-500-main);
      color: white;
    }
    .navbar_dd-navigation-tab .icon-12 {
      width: 0.625rem;
      height: 0.625rem;
      transition: opacity 0.2s ease;
    }
    .navbar_dd-navigation-tab:hover .icon-12.opacity-0 {
      opacity: 1;
    }
    /*Remove default transition on icons*/
    .navbar .icon-24 {
      transition: none;
    }
    .navbar .marketing-icon {
      transition:
        color 0.2s ease,
        background-color 0.2s ease;
    }
    .navbar .button-secondary,
    .navbar .button-tertiary,
    .navbar .button {
      transition:
        transform 0.2s ease,
        background-color 0.2s ease,
        color 0.2s ease;
    }
    /*Hover state on dropdown footer links*/
    .navbar_dd-footer a.paragraph-small:hover {
      text-decoration: underline;
    }
    /*Show arrow on hover for menu cards */
    .navbar_dd-menu-item-card .paragraph-medium:after {
      content: url("data:image/svg+xml,%3Csvg width='100%' height='100%' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M7.33335 1.48433C7.09903 1.25002 6.71913 1.25002 6.48482 1.48433C6.2505 1.71864 6.2505 2.09854 6.48482 2.33286L9.55235 5.40039H0.999902C0.668532 5.40039 0.399902 5.66902 0.399902 6.00039C0.399902 6.33176 0.668532 6.60039 0.999902 6.60039H9.55058L6.48482 9.66615C6.2505 9.90046 6.2505 10.2804 6.48482 10.5147C6.71913 10.749 7.09903 10.749 7.33335 10.5147L11.4053 6.44273C11.5139 6.34312 11.5857 6.20403 11.598 6.0482C11.6117 5.87885 11.5538 5.70479 11.4243 5.57524L7.33335 1.48433Z' fill='currentColor'/%3E%3C/svg%3E%0A");
      display: inline-block;
      width: 0.75rem;
      height: 0.75rem;
      padding-left: 0.5rem;
      position: absolute;
      transform: translateX(-0.5rem);
      opacity: 0;
      transition: 0.2s ease;
      transition-property: transform, opacity;
    }
    .navbar_dd-feature-card.is-resources .paragraph-medium:after {
      content: url("data:image/svg+xml,%3Csvg width='100%' height='100%' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M7.33335 1.48433C7.09903 1.25002 6.71913 1.25002 6.48482 1.48433C6.2505 1.71864 6.2505 2.09854 6.48482 2.33286L9.55235 5.40039H0.999902C0.668532 5.40039 0.399902 5.66902 0.399902 6.00039C0.399902 6.33176 0.668532 6.60039 0.999902 6.60039H9.55058L6.48482 9.66615C6.2505 9.90046 6.2505 10.2804 6.48482 10.5147C6.71913 10.749 7.09903 10.749 7.33335 10.5147L11.4053 6.44273C11.5139 6.34312 11.5857 6.20403 11.598 6.0482C11.6117 5.87885 11.5538 5.70479 11.4243 5.57524L7.33335 1.48433Z' fill='%23FFFFFF'/%3E%3C/svg%3E");
      display: inline-block;
      width: 0.75rem;
      height: 0.75rem;
      padding-left: 0.5rem;
      position: absolute;
      transform: translateX(-0.5rem);
      opacity: 0;
      transition: 0.2s ease;
      transition-property: transform, opacity;
    }
    .navbar_dd-menu-item-card:hover .paragraph-medium:after,
    .navbar_dd-feature-card.is-resources:hover .paragraph-medium:after {
      transform: translateX(0rem);
      opacity: 1;
    }
    .navbar_dd-menu-item-card.is-templates img,
    .navbar_dd-feature-card .navbar_dd-feature-card-img,
    .navbar_dd-feature-card.is-resources .background-cover-image,
    [all-features-card] .background-cover-image {
      transition: transform 0.3s ease-in-out;
    }
    .navbar_dd-menu-item-card.is-templates:hover img,
    .navbar_dd-feature-card:hover .navbar_dd-feature-card-img:not(.navbar_dd-feature-card-img.is-dubbing-bg),
    .navbar_dd-feature-card.is-resources:hover .background-cover-image,
    [all-features-card]:hover .background-cover-image {
      transform: scale(1.05);
    }
  }

  @media screen and (max-width: 991px) {
    .navbar_dropdown-container.is-solutions .navbar_dd-menu-items-grid:last-of-type {
      margin-bottom: 0rem;
    }
    /* max width on feature card paragraph on tablet */
    .navbar_dd-feature-card .z-2 {
      max-width: 9.5rem;
    }
    /* hide scrollbar */
    .navbar_menu-items-wrapper {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .navbar_menu-items-wrapper::-webkit-scrollbar {
      display: none;
    }
  }

  /** Localisation fixes **/

  /* hide elements when navbar too narrow */
  @media screen and (max-width: 1095px) {
    [lang='en'] .navbar_hide-desktop-custom {
      display: none;
    }
  }

  /* pt-br features card */
  @media screen and (min-width: 767px) {
    [lang='pt-br'] [all-features-card] {
      min-height: 11rem;
      grid-column: 1 / 3;
    }
  }
  /* disable clicking on empty links without href value */
  .navbar_dd-menu-item[href='#'] {
    pointer-events: none;
  }

  /* hide elements that doesn't fit on small desktops */
  @media screen and (max-width: 1225px) {
    [lang='de'] .navbar_hide-desktop-custom,
    [lang='fr'] .navbar_hide-desktop-custom,
    [lang='es'] .navbar_hide-desktop-custom,
    [lang='pt-BR'] .navbar_hide-desktop-custom {
      display: none;
    }
  }
  /* hide intercom on secondary locales */
  [lang='de'] iframe#intercom-frame,
  [lang='de'] .intercom-lightweight-app,
  [lang='de'] div#intercom-facade-btn,
  [lang='fr'] iframe#intercom-frame,
  [lang='fr'] .intercom-lightweight-app,
  [lang='fr'] div#intercom-facade-btn,
  [lang='es'] iframe#intercom-frame,
  [lang='es'] .intercom-lightweight-app,
  [lang='es'] div#intercom-facade-btn,
  [lang='es'] .intercom-lightweight-app,
  [lang='pt-BR'] div#intercom-facade-btn {
    display: none !important;
  }

  /* line break on dropdown menu items */
  [lang='fr'] .navbar_dd-menu-item,
  [lang='de'] .navbar_dd-menu-item,
  [lang='es'] .navbar_dd-menu-item,
  [lang='pt-BR'] .navbar_dd-menu-item {
    white-space: normal;
    text-wrap: balance;
  }

  /* case studies background image position */
  [lang='fr'] .navbar_dd-feature-card.is-resources .background-cover-image,
  [lang='de'] .navbar_dd-feature-card.is-resources .background-cover-image,
  [lang='es'] .navbar_dd-feature-card.is-resources .background-cover-image,
  [lang='pt-BR'] .navbar_dd-feature-card.is-resources .background-cover-image {
    object-position: 100% 100%;
    transform-origin: top right;
  }

  /* fix dropdown position */
  @media screen and (min-width: 992px) {
    [lang='fr'] .navbar_dropdown-container.is-solutions {
      left: -19.1rem;
    }
    [lang='fr'] .navbar_dropdown-container.is-resources {
      left: -25.7rem;
    }
    [lang='de'] .navbar_dropdown-container.is-solutions {
      left: -19.3rem;
    }
    [lang='de'] .navbar_dropdown-container.is-resources {
      left: -26.1rem;
    }
    [lang='es'] .navbar_dropdown-container.is-solutions {
      left: -19.9rem;
    }
    [lang='es'] .navbar_dropdown-container.is-resources {
      left: -27.1rem;
    }
    [lang='pt-BR'] .navbar_dropdown-container.is-solutions {
      left: -21rem;
    }
  }

  /* fix visual on feature card */
  @media screen and (min-width: 992px) {
    [lang='fr'] .navbar_dd-feature-card-img,
    [lang='es'] .navbar_dd-feature-card-img,
    [lang='de'] .navbar_dd-feature-card-img.is-dubbing-ui {
      top: 5.5rem;
    }
    [lang='de'] .navbar_dd-feature-card-img:not(.is-dubbing-ui) {
      top: 4rem;
    }
    [lang='fr'] .navbar_dd-feature-card-img.is-dubbing-bg,
    [lang='es'] .navbar_dd-feature-card-img.is-dubbing-bg,
    [lang='de'] .navbar_dd-feature-card-img.is-dubbing-bg {
      top: 7rem;
    }
  }

  @media screen and (max-width: 991px) {
    [lang='fr'] .navbar_dd-feature-card-img.is-dubbing-ui,
    [lang='de'] .navbar_dd-feature-card-img.is-dubbing-ui,
    [lang='es'] .navbar_dd-feature-card-img.is-dubbing-ui,
    [lang='pt-BR'] .navbar_dd-feature-card-img.is-dubbing-ui {
      width: 13.75rem;
      inset: 1.25rem 0 0 55%;
    }
  }

  /* shrink gap on top level links */
  @media screen and (min-width: 991px) and (max-width: 1030px) {
    [lang="de"] .navbar_cta-container,
  /* [lang="fr"] .navbar_cta-container, */
  [lang="es"] .navbar_cta-container,
  [lang="pt-BR"] .navbar_cta-container {
      grid-column-gap: 0.5rem !important;
    }
  }
</style></div><div class="navbar_script w-embed w-script"><script>
document.addEventListener('DOMContentLoaded', function () {

  /* =========================================================
     SCROLL HANDLING
  ========================================================= */
  const NAVBAR_HIDE_SCROLL_DELTA = 40; // Scroll delta to hide navbar
  const NAVBAR_SHOW_SCROLL_DELTA = -20; // Scroll delta to show navbar
  const VARIANT_CHANGE_SCROLL_THRESHOLD = 80; // Scroll threshold for changing the navbar variant
  const RESPONSIVE_WIDTH_QUERY = '(max-width: 767px)'; // Media query for responsive behavior
  const THROTTLE_DELAY = 30; // Delay in ms for the throttle function

  const navbar = document.getElementById('nav'); // Select navbar
  const stickySections = document.querySelectorAll('[data-sticky-section]'); // Select sticky sections
  const originalVariant = navbar.getAttribute('variant'); // Store the original value
  const mobileQuery = window.matchMedia(RESPONSIVE_WIDTH_QUERY); // Cached once — checked on each scroll tick
  const variantNeedsTracking = originalVariant === 'light' || originalVariant === 'dark'; // Only track variant changes when relevant
  let lastScrollPosition = 0; // Track of the last scroll position
  let cumulativeScrollDelta = 0; // Track cumulative scroll distance
  const isAnchorLink = window.location.hash; // Check if URL contains an anchor link
  let initialLoad = true; // Flag to track initial load
  let isScrolledPast = false; // Tracks whether user has scrolled past the variant threshold

  // Function to check and update the navbar variant on load
  function checkAndUpdateNavbarVariantOnLoad() {
    const initialScrollPosition = window.scrollY;
    if (initialScrollPosition > VARIANT_CHANGE_SCROLL_THRESHOLD) {
      navbar.setAttribute('variant', 'null');
      navbar.setAttribute('scrolled', 'true');  // Set 'scrolled' to true when navbar variant changes to null
      isScrolledPast = true;
    } else {
      navbar.setAttribute('variant', originalVariant);
      navbar.setAttribute('scrolled', 'false');  // Set 'scrolled' to false when variant is reset
      isScrolledPast = false;
    }
  }

  // Function to update sticky sections based on navbar visibility
  function updateStickySections(hidden) {
    stickySections.forEach(section => {
      if (hidden) {
        section.classList.add('navbar-hidden-sticky');
      } else {
        section.classList.remove('navbar-hidden-sticky');
      }
    });
  }

  // Function to handle scroll events
  function handleScroll() {
    const currentScrollPosition = window.scrollY;

    // Mobile only: hide/show navbar based on scroll direction
    if (mobileQuery.matches) {
      const scrollDelta = currentScrollPosition - lastScrollPosition;
      if ((cumulativeScrollDelta > 0 && scrollDelta < 0) || (cumulativeScrollDelta < 0 && scrollDelta > 0)) {
        cumulativeScrollDelta = scrollDelta;
      } else {
        cumulativeScrollDelta += scrollDelta;
      }
      if (!initialLoad || !isAnchorLink) applyNavbarStyleChanges();
    }

    // All viewports: update variant only on light/dark pages, only when threshold is crossed
    if (variantNeedsTracking) {
      const shouldBeScrolled = currentScrollPosition > VARIANT_CHANGE_SCROLL_THRESHOLD;
      if (shouldBeScrolled !== isScrolledPast) {
        isScrolledPast = shouldBeScrolled;
        if (shouldBeScrolled) {
          navbar.setAttribute('variant', 'null');
          navbar.setAttribute('scrolled', 'true');
        } else {
          navbar.setAttribute('variant', originalVariant);
          navbar.setAttribute('scrolled', 'false');
        }
      }
    }

    initialLoad = false;
    lastScrollPosition = currentScrollPosition;
  }

  // Function to apply style changes to the navbar
  function applyNavbarStyleChanges() {
    if (cumulativeScrollDelta > NAVBAR_HIDE_SCROLL_DELTA && window.scrollY > 50) {
      navbar.classList.add('navbar-hidden'); // Update navbar position
      updateStickySections(true); // Update sticky position
      cumulativeScrollDelta = 0; // Reset cumulative scroll
    } else if (cumulativeScrollDelta < NAVBAR_SHOW_SCROLL_DELTA) {
      navbar.classList.remove('navbar-hidden'); // Update navbar position
      updateStickySections(false); // Update sticky position
      cumulativeScrollDelta = 0; // Reset cumulative scroll
    }
  }

  // Throttle function to limit the rate of function execution
  function throttle(func, limit) {
    let lastRan = 0;
    let trailingTimer = null;
    return function (...args) {
      const now = Date.now();
      clearTimeout(trailingTimer);
      if (now - lastRan >= limit) {
        lastRan = now;
        func.apply(this, args);
      } else {
        trailingTimer = setTimeout(() => {
          lastRan = Date.now();
          func.apply(this, args);
        }, limit);
      }
    };
  }

  // Call function to check and update navbar variant on initial load
  checkAndUpdateNavbarVariantOnLoad();

  // Single throttled passive scroll listener covering both mobile hide/show and variant tracking
  window.addEventListener('scroll', throttle(handleScroll, THROTTLE_DELAY), { passive: true });

  /* =========================================================
     NO SCROLL WHEN MOBILE MENU IS OPEN + COMBO CLASS FOR TRANSPARENT STYLING
  ========================================================= */
  // Set overflow:hidden on body when clicking burger menu
  document.querySelector('.navbar_burger-icon-wrapper').addEventListener('click', function () {
    const element = this;
    const clicks = element.getAttribute('data-clicks') === 'true'; // because data attributes return as string

    if (clicks) {
      document.body.style.overflow = 'auto';
      navbar.classList.remove('is-open')
    } else {
      document.body.style.overflow = 'hidden';
      navbar.classList.add('is-open')
    }

    element.setAttribute('data-clicks', !clicks);
  });

  // Enable scroll on anchor link click
  document.querySelector(".navbar").addEventListener("click", function (e) {
    if (e.target.closest("a")) {
      document.body.style.overflow = "auto";
      navbar.classList.remove("is-open");
    }
  });

  /* =========================================================
     NAVLINK BOLD ON HOVER
  ========================================================= */
  // Automatically assign an attribute to each navbar link with same value as the link-text
  const navTopLinks = document.querySelectorAll('.navbar_dropdown-toggle .paragraph-medium')
  for (const topLink of navTopLinks) {
    topLink.setAttribute('title', topLink.textContent)
  }

  /* =========================================================
     SHOW BACKGROUND WHEN DROPDOWN MENU IS OPEN
  ========================================================= */
  const menuWrapper = document.querySelector('.navbar_menu-items-wrapper');
  const dropdownWrappers = menuWrapper.querySelectorAll('.w-dropdown');
  const overlay = menuWrapper.querySelector('.navbar_bg-overlay');

  function checkDropdownState() {
    const anyOpen = Array.from(dropdownWrappers).some(wrapper =>
      wrapper.querySelector('.w-dropdown-toggle')?.classList.contains('w--open')
    );
    overlay.classList.toggle('is-visible', anyOpen);
  }

  // Set up MutationObserver configuration
  const observerConfig = { attributes: true, attributeFilter: ['class'] };

  // observerConfig already filters to class attribute changes only — call directly
  const mutationCallback = () => checkDropdownState();

  // Create a new MutationObserver instance
  const observer = new MutationObserver(mutationCallback);

  // Observe the child of each dropdown element for changes in its class within the menu wrapper
  dropdownWrappers.forEach(wrapper => {
    const dropdownChild = wrapper.querySelector('.w-dropdown-list'); // Assuming the child has this class
    if (dropdownChild) {
      observer.observe(dropdownChild, observerConfig);
    }
  });

  // Initial check for already open dropdowns on page load
  checkDropdownState();

  /* =========================================================
     HIDE/SHOW DROPDOWN CONTENT BASED ON TABS
  ========================================================= */
  const TAB_MAP = [
    { tab: 'dd-team-tab',     pane: 'dd-team'     },
    { tab: 'dd-use-case-tab', pane: 'dd-use-case' },
    { tab: 'dd-industry-tab', pane: 'dd-industry' },
  ];

  function initializeDropdownTabs(dropdown) {
    // Pre-compute tab and pane attrs once at setup — no discovery needed on click
    const tabData = TAB_MAP.flatMap(({ tab, pane }) =>
      [...dropdown.querySelectorAll(`[${tab}]`)].map(el => ({ el, tab, pane }))
    );
    const paneData = TAB_MAP.flatMap(({ pane }) =>
      [...dropdown.querySelectorAll(`[${pane}]`)].map(el => ({ el, pane }))
    );

    tabData.forEach(({ el, tab, pane }) => {
      el.addEventListener('click', function () {
        // Reset all tabs and panes
        tabData.forEach(({ el: t, tab: ta }) => t.setAttribute(ta, t.getAttribute(ta).replace('active', '').trim()));
        paneData.forEach(({ el: p, pane: pa }) => p.setAttribute(pa, p.getAttribute(pa).replace('active', '').trim()));

        // Activate clicked tab and matching panes
        el.setAttribute(tab, 'active');
        dropdown.querySelectorAll(`[${pane}]`).forEach(p => p.setAttribute(pane, 'active'));
      });
    });
  }

  // Find all dropdowns and initialize their tab functionality
  const dropdowns = document.querySelectorAll('.navbar_dropdown-wrapper');
  dropdowns.forEach(initializeDropdownTabs);

  /* =========================================================
     LOG IN BUTTON
  ========================================================= */
  const logInButton = document.getElementById("log-in");
  if (logInButton) {
    const loggedInHref = "https://app.synthesia.io/#/?videosType=MyRecentVideos&marketingDirectLogin=true";
    const hasSessionCookie = document.cookie.split("; ").some(c => c.startsWith("synthesia-session-hint="));
    if (hasSessionCookie) {
      logInButton.href = loggedInHref;
    }
  }

});
</script></div></div></nav><div class="main-wrapper"><div class="background-base-dark"><header class="position-relative overflow-hidden"><div class="transparent-navbar_spacer"></div><div class="spacer-xxlarge"></div><div class="background-image-container is-active" data-id="bg-work"><img alt="" class="background-cover-image hide-mobile-landscape" decoding="async" fetchpriority="high" loading="eager" sizes="(max-width: 2880px) 100vw, 2880px" src="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg.webp" srcset="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-500.webp 500w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-800.webp 800w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-1080.webp 1080w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-1600.webp 1600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-2000.webp 2000w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg-p-2600.webp 2600w, https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2b8d7d89da7f6c0aa8997_afdb345c9d33ff4a6d4054e9d0159555_ai-vid-gen-work-bg.webp 2880w"/><div class="show-mobile-landscape is-display-contents"><div class="overflow-hidden display-contents" video-component=""><video autoplay="true" class="html-video lazy min-height-100-percent" data-poster="https://cdn.prod.website-files.com/65e89895c5a4b8d764c0d710/69b2cb1e30df0de91effbf0d_65f3afca18b7a3a55f86c3365aca3